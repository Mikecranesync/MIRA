#!/usr/bin/env bash
# MIRA pre-commit hook — shellcheck + gitleaks + rg debug-artifact scan on staged files
# Installed via: git config core.hooksPath .githooks

set -euo pipefail

PASS=0
FAIL=0
WARNINGS=0

red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

bold "=== MIRA pre-commit checks ==="

# Trace which Claude Code session ran the hook (v2.1+ auto-injects this).
# Empty when invoked from a human terminal — that's expected.
if [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  echo "  ↳ Claude Code session: ${CLAUDE_CODE_SESSION_ID}"
  # In a worktree, `.git` is a file pointing at the real gitdir — `mkdir
  # -p .git/...` fails under `set -e`. Resolve via git rev-parse so this
  # works in both worktrees and the main checkout.
  GITDIR=$(git rev-parse --git-common-dir 2>/dev/null || echo ".git")
  mkdir -p "${GITDIR}/claude-sessions" 2>/dev/null || true
  echo "$(date -u +%FT%TZ) ${CLAUDE_CODE_SESSION_ID} pre-commit" \
    >> "${GITDIR}/claude-sessions/log" 2>/dev/null || true
fi

# Staged files
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

# ------------------------------------------------------------------
# 1. shellcheck on staged .sh files
# ------------------------------------------------------------------
if [ -n "$STAGED_SH" ]; then
  bold "Checking shell scripts..."
  SHELLCHECK_BIN=$(command -v shellcheck 2>/dev/null || echo "/opt/homebrew/bin/shellcheck")
  if [ ! -x "$SHELLCHECK_BIN" ]; then
    yellow "  shellcheck not found — skipping (install: brew install shellcheck)"
    WARNINGS=$((WARNINGS + 1))
  else
    for f in $STAGED_SH; do
      if [ -f "$f" ]; then
        if "$SHELLCHECK_BIN" -S warning "$f" 2>&1; then
          green "  ✓ $f"
          PASS=$((PASS + 1))
        else
          red "  ✗ $f — shellcheck failed"
          FAIL=$((FAIL + 1))
        fi
      fi
    done
  fi
else
  echo "  No .sh files staged."
fi

# ------------------------------------------------------------------
# 2. gitleaks — secrets scan on staged changes (mirrors CI)
# ------------------------------------------------------------------
bold "Scanning staged changes for secrets (gitleaks)..."
GITLEAKS_BIN=$(command -v gitleaks 2>/dev/null || echo "/opt/homebrew/bin/gitleaks")
if [ ! -x "$GITLEAKS_BIN" ]; then
  yellow "  gitleaks not found — skipping (install: brew install gitleaks)"
  WARNINGS=$((WARNINGS + 1))
else
  if "$GITLEAKS_BIN" protect --staged --redact --no-banner --config=.gitleaks.toml 2>&1; then
    green "  ✓ No secrets detected in staged changes"
    PASS=$((PASS + 1))
  else
    red "  🔴 gitleaks detected secrets in staged changes (see above)"
    red "  → False positive? Add to .gitleaks.toml allowlist or use '# gitleaks:allow' comment"
    FAIL=$((FAIL + 1))
  fi
fi

# ------------------------------------------------------------------
# 3. ripgrep — leftover debug artifacts in staged .py files
# ------------------------------------------------------------------
if [ -n "$STAGED_PY" ]; then
  bold "Scanning Python files for debug artifacts..."
  DEBUG_FOUND=0
  for f in $STAGED_PY; do
    if [ -f "$f" ]; then
      RG_BIN=$(command -v rg 2>/dev/null || echo "/opt/homebrew/bin/rg")
      MATCHES=$("$RG_BIN" --no-heading --line-number \
        '^\s*(import pdb|pdb\.set_trace|breakpoint\(\)|import ipdb|ipdb\.set_trace)' \
        "$f" 2>/dev/null || true)
      if [ -n "$MATCHES" ]; then
        yellow "  ⚠️  Debug artifact in $f:"
        echo "$MATCHES" | sed 's/^/    /'
        DEBUG_FOUND=$((DEBUG_FOUND + 1))
        WARNINGS=$((WARNINGS + 1))
      fi
      # Also check for bare print() that look like debugging (not in test files)
      if [[ "$f" != *test* ]] && [[ "$f" != */tests/* ]]; then
        PRINT_MATCHES=$("$RG_BIN" --no-heading --line-number \
          '^\s*print\(' "$f" 2>/dev/null || true)
        if [ -n "$PRINT_MATCHES" ]; then
          yellow "  ⚠️  print() in non-test file $f (use logger instead):"
          echo "$PRINT_MATCHES" | head -3 | sed 's/^/    /'
          [ "$(echo "$PRINT_MATCHES" | wc -l)" -gt 3 ] && echo "    ... and more"
          WARNINGS=$((WARNINGS + 1))
        fi
      fi
    fi
  done
  if [ $DEBUG_FOUND -eq 0 ]; then
    green "  ✓ No debug artifacts found"
    PASS=$((PASS + 1))
  fi
else
  echo "  No .py files staged."
fi

# ------------------------------------------------------------------
# 4. Spec staleness — warn (never block) when API code outpaces docs.
#    Spec: docs/specs/enforcement-layer-spec.md §4.4
# ------------------------------------------------------------------
STAGED_API=$(git diff --cached --name-only --diff-filter=ACM | grep '^mira-hub/src/app/api/' || true)
if [ -n "$STAGED_API" ]; then
  bold "Checking spec freshness for staged API changes..."
  TODAY_EPOCH=$(date -u +%s)
  STALE_DAYS=7

  # Collect unique top-level modules from the staged paths:
  #   mira-hub/src/app/api/work-orders/route.ts → work-orders
  #   mira-hub/src/app/api/assets/[id]/enrich/route.ts → assets
  MODULES=$(echo "$STAGED_API" | sed -E 's|^mira-hub/src/app/api/([^/]+).*$|\1|' | sort -u)

  STALE_FOUND=0
  for module in $MODULES; do
    # Map module → spec, falling back to the platform spec.
    SPEC=""
    for candidate in "docs/specs/${module}-spec.md" "docs/specs/${module}.md"; do
      if [ -f "$candidate" ]; then
        SPEC="$candidate"
        break
      fi
    done
    if [ -z "$SPEC" ]; then
      SPEC="docs/specs/factorylm-platform-v2.md"
    fi
    [ ! -f "$SPEC" ] && continue

    # Read frontmatter `last_updated:` (ISO date, YYYY-MM-DD).
    LAST=$(awk '/^last_updated:/ { print $2; exit }' "$SPEC" 2>/dev/null || true)
    if [ -z "$LAST" ]; then
      yellow "  ⚠️  $SPEC has no \`last_updated:\` frontmatter — consider adding one"
      WARNINGS=$((WARNINGS + 1))
      continue
    fi

    # Cross-platform date diff (BSD `date` on macOS does not accept -d).
    if LAST_EPOCH=$(date -j -u -f "%Y-%m-%d" "$LAST" +%s 2>/dev/null); then
      :
    elif LAST_EPOCH=$(date -u -d "$LAST" +%s 2>/dev/null); then
      :
    else
      LAST_EPOCH=""
    fi
    if [ -z "$LAST_EPOCH" ]; then
      yellow "  ⚠️  Could not parse last_updated:$LAST in $SPEC"
      WARNINGS=$((WARNINGS + 1))
      continue
    fi

    AGE_DAYS=$(( (TODAY_EPOCH - LAST_EPOCH) / 86400 ))
    if [ "$AGE_DAYS" -gt "$STALE_DAYS" ]; then
      yellow "  ⚠️  $SPEC last updated ${AGE_DAYS}d ago (>${STALE_DAYS}d)"
      yellow "      Touched module \`$module\` — consider updating the spec."
      STALE_FOUND=$((STALE_FOUND + 1))
      WARNINGS=$((WARNINGS + 1))
    fi
  done
  if [ $STALE_FOUND -eq 0 ]; then
    green "  ✓ All matched specs are fresh (≤${STALE_DAYS}d)"
    PASS=$((PASS + 1))
  fi
fi

# ------------------------------------------------------------------
# 5. actionlint — GitHub Actions workflow validation on staged workflow
#    files. Catches the duplicate-key / schema / expression errors that
#    GitHub rejects at parse time (e.g. the duplicate `concurrency:` key
#    that broke compose-mem-lint.yml — #1725 — failing in 0s with no logs).
#    Embedded shellcheck is disabled (-shellcheck=) so pre-existing run-block
#    style nits don't block edits; .sh files are shellchecked in section 1.
#    NOTE: skip-if-missing means this only protects machines that have
#    actionlint installed — the non-skippable CI gate is .github/workflows/actionlint.yml.
# ------------------------------------------------------------------
STAGED_WORKFLOWS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^\.github/workflows/.*\.ya?ml$' || true)
if [ -n "$STAGED_WORKFLOWS" ]; then
  bold "Checking GitHub Actions workflows (actionlint)..."
  ACTIONLINT_BIN=$(command -v actionlint 2>/dev/null || echo "/opt/homebrew/bin/actionlint")
  if [ ! -x "$ACTIONLINT_BIN" ]; then
    yellow "  actionlint not found — skipping (install: brew install actionlint)"
    WARNINGS=$((WARNINGS + 1))
  else
    for f in $STAGED_WORKFLOWS; do
      if [ -f "$f" ]; then
        if "$ACTIONLINT_BIN" -shellcheck= "$f" 2>&1; then
          green "  ✓ $f"
          PASS=$((PASS + 1))
        else
          red "  ✗ $f — actionlint failed (GitHub would reject this workflow at parse time)"
          FAIL=$((FAIL + 1))
        fi
      fi
    done
  fi
else
  echo "  No GitHub workflow files staged."
fi

# ------------------------------------------------------------------
# 6. Scope guard — warn (never block) when a commit looks like it swept in
#    foreign WIP / out-of-scope files. Mirrors .claude/rules/session-discipline.md
#    §3 ("stage only files your change touched"). Warn-only by design: a broad
#    commit is sometimes correct, so this nudges, it does not block.
# ------------------------------------------------------------------
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED_ALL" ]; then
  bold "Checking commit scope..."

  # 6a. Known foreign-WIP / noise patterns that should rarely be committed.
  NOISE=$(echo "$STAGED_ALL" | grep -E '(^|/)tools/__init__\.py$|(^|/)ANTIGRAVITY_.*\.md$|(^|/)yt-pipeline/|\.orig$|\.rej$' || true)
  if [ -n "$NOISE" ]; then
    yellow "  ⚠️  Staged files look like foreign WIP / noise (session-discipline §3):"
    echo "$NOISE" | sed 's/^/      /'
    yellow "      If you didn't mean these: git restore --staged <file>"
    WARNINGS=$((WARNINGS + 1))
  fi

  # 6b. Untracked files present alongside a staged commit — did you `git add -A`
  #     over someone else's WIP? Informational; the files are NOT being committed.
  UNTRACKED=$(git ls-files --others --exclude-standard || true)
  if [ -n "$UNTRACKED" ]; then
    UNTRACKED_COUNT=$(printf '%s\n' "$UNTRACKED" | grep -c . || true)
    yellow "  ⚠️  ${UNTRACKED_COUNT} untracked file(s) in the tree (not staged — confirm none belong here):"
    printf '%s\n' "$UNTRACKED" | head -5 | sed 's/^/      /'
    [ "$UNTRACKED_COUNT" -gt 5 ] && echo "      ... and $((UNTRACKED_COUNT - 5)) more"
    yellow "      Never 'git add -A' over foreign WIP — stage explicit paths."
    WARNINGS=$((WARNINGS + 1))
  fi

  if [ -z "$NOISE" ] && [ -z "$UNTRACKED" ]; then
    green "  ✓ Commit scope clean (no foreign WIP / noise staged or loose)"
    PASS=$((PASS + 1))
  fi
fi

# ------------------------------------------------------------------
# Summary
# ------------------------------------------------------------------
bold ""
bold "=== Pre-commit summary ==="
green  "  Passed:   $PASS"
yellow "  Warnings: $WARNINGS"
[ $FAIL -gt 0 ] && red "  Failed:   $FAIL" || echo "  Failed:   0"

if [ $FAIL -gt 0 ]; then
  red ""
  red "Commit blocked — fix the above issues before committing."
  red "To bypass (not recommended): git commit --no-verify"
  exit 1
fi

if [ $WARNINGS -gt 0 ]; then
  yellow "Warnings present — commit allowed but please review."
fi

exit 0
