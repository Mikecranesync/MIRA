#!/bin/bash
# Pre-commit hook: catch common issues before they reach CI

echo "Running pre-commit checks..."

# ShellCheck staged .sh files
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)
if [ -n "$STAGED_SH" ]; then
    echo "--- ShellCheck ---"
    for f in $STAGED_SH; do
        if ! shellcheck "$f" 2>/dev/null; then
            echo "❌ ShellCheck failed on $f"
            exit 1
        fi
    done
    echo "✅ ShellCheck passed"
fi

# Ripgrep for hardcoded credentials and debug statements
echo "--- Credential/Debug scan ---"
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
    CRED_FOUND=0
    DEBUG_FOUND=0
    for f in $STAGED_PY; do
        # Check for hardcoded passwords/tokens
        if rg -q '(password|secret|token|api_key)\s*=\s*["'"'"'][^"'"'"']{8,}' "$f" 2>/dev/null; then
            echo "⚠️  Possible hardcoded credential in $f:"
            rg -n '(password|secret|token|api_key)\s*=\s*["'"'"']' "$f" 2>/dev/null
            echo "   Add '# noqa: credential' comment if this is intentional."
            CRED_FOUND=1
        fi

        # Check for leftover debug statements
        if rg -q '^\s*(print\(|breakpoint\(\)|import pdb)' "$f" 2>/dev/null; then
            echo "⚠️  Debug statement in $f:"
            rg -n '^\s*(print\(|breakpoint\(\)|import pdb)' "$f" 2>/dev/null
            DEBUG_FOUND=1
        fi

        # Check for yaml.load without Loader (unsafe)
        if rg -q 'yaml\.load\([^,)]+\)' "$f" 2>/dev/null; then
            echo "❌ Unsafe yaml.load() in $f — use yaml.safe_load()"
            rg -n 'yaml\.load\(' "$f" 2>/dev/null
            exit 1
        fi

        # Check for subprocess shell=True
        if rg -q 'subprocess\.(run|call|Popen)\(.*shell=True' "$f" 2>/dev/null; then
            echo "❌ subprocess with shell=True in $f — potential shell injection"
            rg -n 'shell=True' "$f" 2>/dev/null
            exit 1
        fi
    done

    if [ $CRED_FOUND -eq 1 ]; then
        echo "⚠️  Review credential warnings above before pushing."
    fi
    echo "✅ Credential/debug scan done"
fi

echo "Pre-commit checks complete."
