#!/usr/bin/env bash
# MIRA post-merge hook — refresh CodeGraph index after merges and pulls.
# Installed via: git config core.hooksPath .githooks
#
# Two-step refresh (ref: docs/tech-debt/2026-06-09-codegraph-evaluation.md):
#   1. `codegraph sync` — fast incremental pickup of the merged files.
#   2. corruption canary — sync does NOT repair dropped call edges; the canary
#      checks a known-good hot symbol and runs `index --force` if the call-graph
#      has collapsed (the silent FK-failure corruption the watcher introduces).
#
# The hook never blocks the merge: it runs detached in the background, and
# codegraph missing / npx offline / any failure degrades to a logged line.
# Progress is appended to .codegraph/hook.log (gitignored, per-checkout).

set -u

# Skip when CodeGraph isn't installed in this checkout (e.g. fresh clone
# before `npx -y @colbymchenry/codegraph init -i`, or a worktree that
# was created before install).
if [ ! -d ".codegraph" ]; then
  exit 0
fi

# Skip when npx is unavailable (CI minimal images, restricted shells).
if ! command -v npx >/dev/null 2>&1; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Background + detached so a slow npm cache check / reindex never delays the
# merge. All output goes to the hook log; the next query surfaces health.
(
  LOG="$REPO_ROOT/.codegraph/hook.log"
  CANARY=skipped
  {
    echo "[$(date '+%Y-%m-%dT%H:%M:%S')] post-merge: codegraph sync"
    npx -y @colbymchenry/codegraph sync >/dev/null 2>&1 || true

    # sync can't undo a corrupted edge set — let the canary force-reindex if
    # the hot-symbol caller count has collapsed.
    if [ -x "$REPO_ROOT/tools/codegraph-canary.sh" ]; then
      "$REPO_ROOT/tools/codegraph-canary.sh"
      case $? in
        0) CANARY=healthy; echo "post-merge: canary healthy" ;;
        1) CANARY=repaired; echo "post-merge: canary detected corruption and repaired via index --force" ;;
        *) CANARY=failed; echo "post-merge: canary FAILED to repair — run tools/codegraph-force-reindex.sh by hand" ;;
      esac
    else
      echo "post-merge: canary script absent — skipped corruption check"
    fi

    # Freshness marker — lets the next AI task / preflight detect staleness or
    # a failed sync without re-deriving it. Read by tools/codegraph-preflight.sh.
    {
      echo "ts=$(date '+%Y-%m-%dT%H:%M:%S')"
      echo "head=$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null)"
      echo "event=post-merge"
      echo "npx=ok"
      echo "index=present"
      echo "canary=$CANARY"
    } > "$REPO_ROOT/.codegraph/.last-sync" 2>/dev/null || true
  } >>"$LOG" 2>&1
) &
disown 2>/dev/null || true

exit 0
