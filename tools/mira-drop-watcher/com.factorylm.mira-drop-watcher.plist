<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.factorylm.mira-drop-watcher</string>

    <!-- install.sh substitutes __HOME__ / __DOPPLER__ / __PYTHON__ / __WATCHER_DIR__ -->
    <key>ProgramArguments</key>
    <array>
        <string>__DOPPLER__</string>
        <string>run</string>
        <string>-p</string>
        <string>factorylm</string>
        <string>-c</string>
        <string>dev</string>
        <string>--</string>
        <string>__PYTHON__</string>
        <string>__WATCHER_DIR__/main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__WATCHER_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/mira-drop-watcher.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/mira-drop-watcher.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
