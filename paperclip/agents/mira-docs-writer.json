{
  "name": "mira-docs-writer",
  "description": "Documentation maintenance. Keeps docs, ADRs, changelogs, and runbooks in sync with code changes.",
  "adapter": "claude_local",
  "model": "claude-sonnet-4-6",
  "effort": "medium",
  "maxTurnsPerRun": 30,
  "timeoutSec": 300,
  "graceSec": 20,
  "cwd": "__MIRA_HOME__",
  "instructionsFilePath": "__MIRA_HOME__/paperclip/instructions/docs-writer.md",
  "workspaceStrategy": { "type": "none" },
  "extraArgs": [
    "--mcp-config", "__MIRA_HOME__/paperclip/mcp-config.json"
  ],
  "env": {},
  "dangerouslySkipPermissions": false
}
