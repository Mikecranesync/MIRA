{
  "name": "mira-orchestrator",
  "description": "Top-level coordinator. Decomposes development tasks, delegates to specialist agents, reviews PRs, merges completed work.",
  "adapter": "claude_local",
  "model": "claude-opus-4-6",
  "effort": "high",
  "maxTurnsPerRun": 100,
  "timeoutSec": 1200,
  "graceSec": 30,
  "cwd": "__MIRA_HOME__",
  "instructionsFilePath": "__MIRA_HOME__/paperclip/instructions/orchestrator.md",
  "workspaceStrategy": { "type": "none" },
  "extraArgs": [
    "--mcp-config", "__MIRA_HOME__/paperclip/mcp-config.json"
  ],
  "env": {},
  "dangerouslySkipPermissions": false
}
