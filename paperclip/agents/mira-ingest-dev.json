{
  "name": "mira-ingest-dev",
  "description": "Knowledge pipeline development. Works on mira-core/, mira-mcp/, tools/ — ingest service, NeonDB, MCP server, photo pipeline.",
  "adapter": "claude_local",
  "model": "claude-sonnet-4-6",
  "effort": "high",
  "maxTurnsPerRun": 50,
  "timeoutSec": 600,
  "graceSec": 30,
  "cwd": "__MIRA_HOME__",
  "instructionsFilePath": "__MIRA_HOME__/paperclip/instructions/ingest-dev.md",
  "workspaceStrategy": { "type": "git_worktree" },
  "extraArgs": [
    "--mcp-config", "__MIRA_HOME__/paperclip/mcp-config.json"
  ],
  "env": {},
  "dangerouslySkipPermissions": false
}
