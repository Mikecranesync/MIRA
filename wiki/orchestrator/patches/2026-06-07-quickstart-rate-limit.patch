From: MIRA beta-readiness orchestrator (Lens A, 2026-06-07)
Subject: [PATCH] security(hub): rate-limit public /api/quickstart/ask LLM endpoint

WHY: /api/quickstart/ask is unauthenticated and fires a cascadeComplete (Groq->
Cerebras->Gemini, all shared free-tier) on every POST. With no throttle a single
script drains the provider quota for the entire beta cohort (and/or runs up cost).
This adds a per-IP-hash limiter mirroring the proven /api/public/report pattern,
but in-memory (no migration needed for the beta gate).

CAVEAT: in-memory limiter is per-instance. mira-hub on app.factorylm.com runs as a
single container today (see Container Map), so this is sufficient for beta. If/when
the hub scales horizontally, port to the DB-backed counter (a quickstart_rate table)
or a shared store. Tracked as a follow-up.

APPLY:
  cd <repo-root-MIRA>
  git checkout -b fix/quickstart-rate-limit
  git apply --reject wiki/orchestrator/patches/2026-06-07-quickstart-rate-limit.patch
  # if context drifted, see MANUAL STEPS below

VERIFY:
  cd mira-hub
  npx tsc --noEmit                      # types clean
  # functional: 21st request within 60s from one IP must return HTTP 429
  for i in $(seq 1 21); do curl -s -o /dev/null -w "%{http_code}\n" \
    -X POST localhost:3200/api/quickstart/ask \
    -H 'content-type: application/json' -d '{"question":"test"}'; done | tail -3

--- a/mira-hub/src/app/api/quickstart/ask/route.ts
+++ b/mira-hub/src/app/api/quickstart/ask/route.ts
@@ -1,5 +1,7 @@
 import { NextResponse } from "next/server";
+import { headers } from "next/headers";
+import { createHash } from "crypto";
 import { withTenantContext } from "@/lib/tenant-context";
 import { cascadeComplete, type CascadeMessage } from "@/lib/llm/cascade";
 import {
   retrieveManualChunks,
   buildGroundedContext,
   type ManualChunk,
   type ManualSource,
 } from "@/lib/manual-rag";

 export const dynamic = "force-dynamic";

+// Per-IP-hash rate limit for this public, unauthenticated LLM endpoint.
+// In-memory (per-instance) — sufficient while the hub runs as a single container.
+// Mirrors the intent of /api/public/report's DB-backed IP-hash limiter.
+const QUICKSTART_MAX_PER_MIN = 20;
+const QUICKSTART_WINDOW_MS = 60_000;
+const quickstartHits = new Map<string, number[]>();
+
+function quickstartRateLimited(ipHash: string): boolean {
+  const now = Date.now();
+  const cutoff = now - QUICKSTART_WINDOW_MS;
+  const hits = (quickstartHits.get(ipHash) ?? []).filter((t) => t > cutoff);
+  hits.push(now);
+  quickstartHits.set(ipHash, hits);
+  // opportunistic cleanup so the map can't grow unbounded
+  if (quickstartHits.size > 5000) {
+    for (const [k, v] of quickstartHits) {
+      if (v.every((t) => t <= cutoff)) quickstartHits.delete(k);
+    }
+  }
+  return hits.length > QUICKSTART_MAX_PER_MIN;
+}
+
@@ -67,6 +69,17 @@ export async function POST(req: Request) {
   if (!process.env.NEON_DATABASE_URL) {
     return NextResponse.json({ error: "DB not configured" }, { status: 503 });
   }

+  // Rate limit before doing any work — we never store raw IPs.
+  const hdrs = await headers();
+  const rawIp =
+    hdrs.get("x-forwarded-for")?.split(",")[0]?.trim() ??
+    hdrs.get("x-real-ip") ??
+    "unknown";
+  const ipHash = createHash("sha256").update(rawIp).digest("hex");
+  if (quickstartRateLimited(ipHash)) {
+    return NextResponse.json(
+      { error: "Too many requests — slow down and try again in a minute." },
+      { status: 429 },
+    );
+  }
+
   let body: AskPayload;
