# mira-sidecar environment variables
# Copy this file to .env for local development ONLY.
# Production: inject via Doppler (factorylm/prd). Never commit real keys.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# One of: openai | anthropic | ollama
LLM_PROVIDER=ollama

# OpenAI settings (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=
LLM_MODEL_OPENAI=gpt-4o-mini

# Anthropic settings (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-6

# Ollama settings (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_OLLAMA=llama3

# ---------------------------------------------------------------------------
# Embedding provider selection
# ---------------------------------------------------------------------------
# One of: openai | ollama
# NOTE: When LLM_PROVIDER=anthropic, embedding is ALWAYS forced to ollama
#       regardless of this setting (Anthropic has no embedding API).
EMBEDDING_PROVIDER=ollama

# OpenAI embedding model (used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama embedding model (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# Sidecar network binding
# ---------------------------------------------------------------------------
# NEVER change HOST to 0.0.0.0 — sidecar is local-only
HOST=127.0.0.1
PORT=5000

# ---------------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------------
DOCS_BASE_PATH=./docs
CHROMA_PATH=./chroma_data

# ---------------------------------------------------------------------------
# Path B — Tier routing (feature-flagged, off by default)
# ---------------------------------------------------------------------------
# Enable to route queries between local Ollama (Tier 1) and Claude (Tier 3).
# Requires TIER1_OLLAMA_URL to point to a reachable Ollama instance.
TIER_ROUTING_ENABLED=false
TIER1_OLLAMA_URL=
TIER1_MODEL=gemma4:e4b
TIER1_TIMEOUT=15
TIER1_MAX_QUERY_WORDS=40
TIER2_GPU_URL=
TIER2_MODEL=gemma4:26b
TIER2_TIMEOUT=45
TIER2_API_KEY=
HEALTH_PROBE_INTERVAL=30

# ---------------------------------------------------------------------------
# FSM anomaly detection thresholds
# ---------------------------------------------------------------------------
FSM_N_SIGMA=2.5
FSM_STUCK_MULTIPLIER=3.0
FSM_RARE_THRESHOLD=0.005
FSM_MIN_BASELINE_CYCLES=50

# ---------------------------------------------------------------------------
# Optional: Java-style .properties file
# ---------------------------------------------------------------------------
# Point to a key=value properties file for customer Ignition server deployments.
# Environment variables always override values read from this file.
PROPERTIES_FILE=
