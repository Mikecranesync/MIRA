# Vision (GPT-4o)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o

# MIRA RAG (mira-pipeline fallback path)
MIRA_KB_BASE_URL=
MIRA_KB_API_KEY=
MIRA_KB_TIMEOUT=30

# Manufacturer-scoped RAG (preferred when scan matches a known asset).
# When enabled, the chat backend retrieves chunks from `knowledge_entries`
# filtered by manufacturer and calls the LLM cascade directly. Requires
# at least one of GROQ_API_KEY / CEREBRAS_API_KEY / GEMINI_API_KEY plus
# NEON_DATABASE_URL. Falls back to MIRA_KB_BASE_URL if any piece is missing.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
VENDOR_RAG_TOP_K=5
VENDOR_RAG_LLM_TIMEOUT=30
MIRA_SHARED_TENANT_ID=78917b56-f85f-43bb-9a08-1bb98a6cd6c3

# monday.com — server-side write fallback (used by the standalone
# /scan/ path that doesn't run inside a Monday iframe). For the
# marketplace app, per-account OAuth tokens replace this on a per-call
# basis — see MONDAY_OAUTH_* below.
MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_API_VERSION=2024-01

# monday.com OAuth 2.0 — required for the marketplace install flow.
# Get these from your app in monday.com's Developer Center.
# Redirect URI must match exactly what's configured there.
MONDAY_OAUTH_CLIENT_ID=
MONDAY_OAUTH_CLIENT_SECRET=
MONDAY_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/monday/callback
MONDAY_OAUTH_SCOPES=me:read boards:read boards:write
# Defaults to MONDAY_OAUTH_CLIENT_SECRET if unset; override only if
# Monday ever splits the JWT signing key from the OAuth secret.
MONDAY_SIGNING_SECRET=

# monday.com app-lifecycle webhook (install / uninstall / subscription).
# Set in Developer Center → Build → Webhooks; signing secret is shown
# after saving the webhook URL. Defaults to MONDAY_OAUTH_CLIENT_SECRET
# if unset (monday signs lifecycle deliveries with the same key).
MONDAY_WEBHOOK_SIGNING_SECRET=
MONDAY_WEBHOOK_PATH=/monday/webhook

# Optional column-id overrides (defaults match field names)
MONDAY_COL_MAKE=make
MONDAY_COL_MODEL=model
MONDAY_COL_SERIAL=serial
MONDAY_COL_VOLTAGE=voltage
MONDAY_COL_HP=hp
MONDAY_COL_RPM=rpm
MONDAY_COL_HZ=hz
MONDAY_COL_FRAME=frame

# CORS
ALLOWED_ORIGINS=https://*.monday.com,http://localhost:5173

# NeonDB (live kb_chunks lookup + mira_scan_queue)
NEON_DATABASE_URL=
DB_QUERY_TIMEOUT_MS=5000

# Real-time manual search (Serper.dev — Google Search wrapper)
SERPER_API_KEY=
MANUAL_SEARCH_TIMEOUT=15

# Crawler bridge — points the backend at the existing crawler queue.
# On the VPS: MANUAL_QUEUE_HOST_DIR=/opt/mira/mira-crawler/cron
# In the container we always read from the canonical mount path.
MANUAL_QUEUE_HOST_DIR=
MANUAL_QUEUE_JSON_PATH=/data/mira-crawler-cron/manual_queue.json
MIRA_SCAN_DOWNLOAD_PRIORITY=8

# Logging
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_FACTORYLM_SIGNUP_URL=https://app.factorylm.com/signup
