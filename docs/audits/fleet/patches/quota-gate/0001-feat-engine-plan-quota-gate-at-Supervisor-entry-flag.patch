+                quota_tenant,
+                platform,
+                quota_reason,
+            )
+            return QUOTA_BLOCK_MESSAGE
         # Read-only live-tag snapshot — gated on a confirmed asset (see helper).
         message = self._maybe_attach_live_snapshot(chat_id, message, live_tags, platform)
 
