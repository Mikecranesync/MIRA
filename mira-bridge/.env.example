# mira-bridge — Node-RED configuration
NODERED_PORT=1880
TZ=America/New_York

# Path to shared mira.db directory (bind mount)
# mira-mcp reads from this same path
MIRA_DB_PATH=./data

# Slack incoming webhook for scheduled task alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
