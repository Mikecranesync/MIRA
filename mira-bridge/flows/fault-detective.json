    {
        "id": "fd-fn-chat",
        "type": "function",
        "z": "fd-tab",
        "name": "compose chat request",
        "func": "// For the booth demo, call Groq directly. The full Supervisor at\n// mira-pipeline:9099 owns intent + safety + FSM and is tuned for real\n// technician chat \u2014 it short-circuits if the embedded fault context\n// trips safety keywords, which makes booth demos messy. Production\n// chat should still route through the Supervisor.\nconst fault = flow.get('current_fault') || {fault: 'ok'};\nconst question = msg.payload || '';\nconst evidence = (fault.evidence || []).map(e => `- ${e.topic}: ${JSON.stringify(e.value)}${e.note ? ' (' + e.note + ')' : ''}`).join('\\n');\nconst affected = (fault.affected_components || []).join(', ');\nconst lower = question.toLowerCase();\nif (/(^|\\s)(yes|confirm|correct|ok|yep|yeah|y)(\\s|$|[.!])/.test(lower)) {\n    flow.set('confirmed_session', true);\n}\nconst confirmedNow = flow.get('confirmed_session') || false;\nconst sys = [\n    'You are MIRA \u2014 a calm, evidence-based maintenance supervisor.',\n    'You answer briefly. You cite evidence. You never invent plant data.',\n    '',\n    'LIVE CONVEYOR STATE (Demo Cell / Conveyor CV-101):',\n    '  active fault: ' + (fault.fault || 'ok'),\n    '  confidence: ' + (fault.confidence || 0),\n    '  affected components: ' + (affected || 'none'),\n    '  evidence:',\n    (evidence || '  (no evidence yet)'),\n    '  recommended first check (raw): ' + (fault.recommended_first_check || 'n/a'),\n    '  safety note (raw): ' + (fault.safety_note || 'standard plant PPE'),\n    '',\n    confirmedNow\n        ? 'The technician has CONFIRMED the location. Reply directly with: diagnosis, confidence, evidence (bulleted), recommended first check, next measurement, safety note, work-order draft (one line). Under 180 words.'\n        : 'MIRA protocol \u2014 first reply must be EXACTLY: \"I believe you are working on Demo Cell / Conveyor CV-101 / ' + (affected || 'the suspected fault area') + '. Confirm?\" \u2014 then stop. Do not diagnose until the technician says yes.',\n].join('\\n');\nmsg.url = 'https://api.groq.com/openai/v1/chat/completions';\nmsg.method = 'POST';\nmsg.headers = {\n    'Content-Type': 'application/json',\n    'Authorization': 'Bearer ' + env.get('GROQ_API_KEY'),\n};\nmsg.payload = {\n    model: 'llama-3.3-70b-versatile',\n    messages: [\n        {role: 'system', content: sys},\n        {role: 'user', content: question},\n    ],\n    stream: false,\n    temperature: 0.2,\n    max_tokens: 400,\n};\nreturn msg;\n",
        "outputs": 1,
        "x": 380,
        "y": 680,
        "wires": [
            [
                "fd-http-chat"
            ]
        ]
    },
