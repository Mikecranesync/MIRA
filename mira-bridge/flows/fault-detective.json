            ]
        ]
    },
    {
        "id": "fd-fn-waiting",
        "type": "function",
        "z": "fd-tab",
        "name": "extract value",
        "func": "msg.payload = (msg.payload && msg.payload.value) ? msg.payload.value : 'nothing';\nreturn msg;\n",
        "outputs": 1,
        "x": 360,
        "y": 200,
        "wires": [
            [
                "fd-waiting"
            ]
        ]
    },
    {
        "id": "fd-waiting",
