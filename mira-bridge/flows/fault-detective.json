    {
        "id": "fd-mqtt-in-fault",
        "type": "mqtt in",
        "z": "fd-tab",
        "name": "current_fault",
        "topic": "demo/cell1/conveyor/cv101/diagnostics/current_fault",
        "qos": "0",
        "datatype": "json",
        "broker": "fd-mqtt",
        "x": 140,
        "y": 80,
        "wires": [
            [
                "fd-fn-fault-route"
            ]
        ]
    },
    {
        "id": "fd-fn-fault-route",
        "type": "function",
        "z": "fd-tab",
        "name": "route fault",
        "func": "flow.set('current_fault', msg.payload);\nreturn [msg, msg];\n",
        "outputs": 2,
        "x": 360,
        "y": 80,
        "wires": [
            [
                "fd-svg"
            ],
            [
                "fd-fn-banner"
            ]
        ]
    },
    {
        "id": "fd-fn-banner",
        "type": "function",
        "z": "fd-tab",
        "name": "compose banner",
        "func": "const f = msg.payload || {};\nlet header = 'Everything is OK';\nlet detail = '';\nlet color = '#4caf50';\nif (f.fault && f.fault !== 'ok') {\n    header = f.fault.replace(/_/g, ' ').toUpperCase();\n    detail = (f.recommended_first_check || '') + (f.safety_note ? '\\n\\n[SAFETY] ' + f.safety_note : '');\n    color = f.confidence >= 0.85 ? '#f44336' : '#ff9800';\n}\nmsg.payload = `**${header}**\\n\\n${detail}`;\nmsg.ui_update = {color};\nreturn msg;\n",
        "outputs": 1,
        "x": 600,
        "y": 80,
        "wires": [
            [
                "fd-banner"
            ]
        ]
    },
    {
        "id": "fd-banner",
        "type": "ui-text",
        "z": "fd-tab",
        "group": "fd-group-state",
        "name": "Banner",
        "label": "",
        "order": 1,
        "width": "12",
        "height": "0",
        "format": "{{msg.payload}}",
        "layout": "row-spread",
        "style": false,
        "font": "",
        "fontSize": "16",
        "color": "#ffffff",
        "x": 820,
        "y": 80,
        "wires": []
    },
    {
        "id": "fd-mqtt-in-waiting",
        "type": "mqtt in",
        "z": "fd-tab",
        "name": "waiting_on",
        "topic": "demo/cell1/conveyor/cv101/state/waiting_on",
        "qos": "0",
