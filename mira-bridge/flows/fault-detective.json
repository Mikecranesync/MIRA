        "x": 580,
        "y": 200,
        "wires": []
    },
    {
        "id": "fd-svg",
        "type": "ui-template",
        "z": "fd-tab",
        "group": "fd-group-svg",
        "page": "",
        "ui": "",
        "name": "Conveyor SVG",
        "order": 1,
        "width": "12",
        "height": "8",
        "head": "",
        "format": "<template>\n  <div style=\"width:100%; text-align:center; background:#0d0d0d; padding:8px; border-radius:4px;\">\n    <svg viewBox=\"0 0 800 280\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%; max-width:900px;\">\n      <defs>\n        <linearGradient id=\"belt\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"#444\"/>\n          <stop offset=\"100%\" stop-color=\"#222\"/>\n        </linearGradient>\n      </defs>\n      <rect x=\"60\" y=\"160\" width=\"680\" height=\"38\" fill=\"url(#belt)\" stroke=\"#888\" stroke-width=\"1\"/>\n      <circle cx=\"60\" cy=\"179\" r=\"22\" fill=\"#666\" stroke=\"#aaa\" stroke-width=\"1\"/>\n      <circle cx=\"740\" cy=\"179\" r=\"22\" fill=\"#666\" stroke=\"#aaa\" stroke-width=\"1\"/>\n\n      <rect :id=\"'fd-zone1'\" x=\"110\" y=\"150\" width=\"200\" height=\"58\" fill=\"none\" :stroke=\"colorFor('Zone 1')\" stroke-width=\"2\" stroke-dasharray=\"4,3\"/>\n      <text x=\"210\" y=\"144\" fill=\"#bbb\" font-size=\"11\" text-anchor=\"middle\">Zone 1</text>\n\n      <rect :id=\"'fd-zone2'\" x=\"380\" y=\"150\" width=\"260\" height=\"58\" fill=\"none\" :stroke=\"colorFor('Zone 2')\" stroke-width=\"2\" stroke-dasharray=\"4,3\"/>\n      <text x=\"510\" y=\"144\" fill=\"#bbb\" font-size=\"11\" text-anchor=\"middle\">Zone 2</text>\n\n      <circle :id=\"'fd-pe101'\" cx=\"180\" cy=\"110\" r=\"14\" :fill=\"colorFor('PE-101')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"180\" y=\"96\" fill=\"#eee\" font-size=\"11\" text-anchor=\"middle\">PE-101</text>\n      <line x1=\"180\" y1=\"124\" x2=\"180\" y2=\"160\" :stroke=\"colorFor('PE-101')\" stroke-width=\"1\" stroke-dasharray=\"2,2\"/>\n\n      <circle :id=\"'fd-pe102'\" cx=\"460\" cy=\"110\" r=\"14\" :fill=\"colorFor('PE-102')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"460\" y=\"96\" fill=\"#eee\" font-size=\"11\" text-anchor=\"middle\">PE-102</text>\n      <line x1=\"460\" y1=\"124\" x2=\"460\" y2=\"160\" :stroke=\"colorFor('PE-102')\" stroke-width=\"1\" stroke-dasharray=\"2,2\"/>\n\n      <circle :id=\"'fd-px101'\" cx=\"570\" cy=\"110\" r=\"14\" :fill=\"colorFor('PX-101')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"570\" y=\"96\" fill=\"#eee\" font-size=\"11\" text-anchor=\"middle\">PX-101</text>\n      <line x1=\"570\" y1=\"124\" x2=\"570\" y2=\"160\" :stroke=\"colorFor('PX-101')\" stroke-width=\"1\" stroke-dasharray=\"2,2\"/>\n\n      <rect :id=\"'fd-motor'\" x=\"690\" y=\"220\" width=\"60\" height=\"40\" :fill=\"colorFor('Motor M-101')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"720\" y=\"245\" fill=\"#000\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"bold\">M-101</text>\n\n      <rect :id=\"'fd-vfd'\" x=\"690\" y=\"30\" width=\"60\" height=\"40\" :fill=\"colorFor('VFD-101')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"720\" y=\"55\" fill=\"#000\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"bold\">VFD-101</text>\n\n      <circle :id=\"'fd-sl'\" cx=\"50\" cy=\"50\" r=\"14\" :fill=\"colorFor('SL-101')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"50\" y=\"32\" fill=\"#eee\" font-size=\"11\" text-anchor=\"middle\">SL-101</text>\n\n      <rect :id=\"'fd-f2'\" x=\"10\" y=\"220\" width=\"60\" height=\"22\" :fill=\"colorFor('Fuse F2')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"40\" y=\"235\" fill=\"#000\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"bold\">F2 24V</text>\n      <line x1=\"70\" y1=\"231\" x2=\"180\" y2=\"124\" :stroke=\"colorFor('Fuse F2')\" stroke-width=\"1\" stroke-dasharray=\"2,3\"/>\n      <line x1=\"70\" y1=\"231\" x2=\"460\" y2=\"124\" :stroke=\"colorFor('Fuse F2')\" stroke-width=\"1\" stroke-dasharray=\"2,3\"/>\n      <line x1=\"70\" y1=\"231\" x2=\"570\" y2=\"124\" :stroke=\"colorFor('Fuse F2')\" stroke-width=\"1\" stroke-dasharray=\"2,3\"/>\n\n      <rect :id=\"'fd-f3'\" x=\"10\" y=\"250\" width=\"60\" height=\"22\" :fill=\"colorFor('Fuse F3')\" stroke=\"#fff\" stroke-width=\"1\"/>\n      <text x=\"40\" y=\"265\" fill=\"#000\" font-size=\"11\" text-anchor=\"middle\" font-weight=\"bold\">F3 24V</text>\n      <line x1=\"70\" y1=\"261\" x2=\"50\" y2=\"64\" :stroke=\"colorFor('Fuse F3')\" stroke-width=\"1\" stroke-dasharray=\"2,3\"/>\n\n      <text x=\"400\" y=\"24\" fill=\"#fff\" font-size=\"14\" text-anchor=\"middle\" font-weight=\"bold\">CV-101 \u2014 Demo Cell</text>\n      <text x=\"400\" y=\"265\" :fill=\"bannerColor\" font-size=\"13\" text-anchor=\"middle\" font-weight=\"bold\">{{ faultLabel }}</text>\n    </svg>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return { fault: { fault: 'ok', affected_components: [], confidence: 1.0 } };\n  },\n  watch: {\n    msg(m) {\n      if (m && m.payload) this.fault = m.payload;\n    },\n  },\n  computed: {\n    affected() {\n      return new Set(this.fault.affected_components || []);\n    },\n    bannerColor() {\n      if (!this.fault.fault || this.fault.fault === 'ok') return '#4caf50';\n      return this.fault.confidence >= 0.85 ? '#f44336' : '#ff9800';\n    },\n    faultLabel() {\n      if (!this.fault.fault || this.fault.fault === 'ok') return 'STATUS: OK';\n      const conf = Math.round((this.fault.confidence || 0) * 100);\n      return this.fault.fault.replace(/_/g, ' ').toUpperCase() + '   (' + conf + '% confidence)';\n    },\n  },\n  methods: {\n    colorFor(component) {\n      if (this.affected.has(component)) {\n        return this.fault.confidence >= 0.85 ? '#f44336' : '#ff9800';\n      }\n      return '#4caf50';\n    },\n  },\n};\n</script>\n",
        "storeOutMessages": true,
        "passthru": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 600,
        "y": 40,
        "wires": [
            []
        ]
    },
