{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "meta": { "name": "Title" },
        "position": { "basis": "48px", "shrink": 0 },
        "props": {
          "style": {
            "color": "#FFFFFF",
            "fontSize": "22px",
            "fontWeight": "bold",
            "letterSpacing": "3px",
            "padding": "8px 16px"
          },
          "text": "SPEED CONTROL"
        },
        "type": "ia.display.label"
      },
      {
        "meta": { "name": "WarningBanner" },
        "position": { "basis": "44px", "shrink": 0 },
        "props": {
          "style": {
            "backgroundColor": "#3a2800",
            "borderLeft": "4px solid #FFBB33",
            "borderRadius": "4px",
            "color": "#FFBB33",
            "fontSize": "13px",
            "fontWeight": "bold",
            "margin": "4px 16px",
            "padding": "10px 16px"
          },
          "text": "⚠  VFD must be in REMOTE mode before writing commands (set P00.21=2 on VFD keypad)"
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": { "name": "SetpointLabel" },
            "position": { "basis": "auto" },
            "props": {
              "style": {
                "color": "#AAAAAA",
                "fontSize": "13px",
                "marginBottom": "8px"
              },
              "text": "FREQUENCY SETPOINT (Hz)"
            },
            "type": "ia.display.label"
          },
          {
            "meta": { "name": "FreqSlider" },
            "position": { "basis": "40px", "shrink": 0 },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "tagPath": "[default]Conveyor/VFD_Setpoint_Hz",
                    "bidirectional": false
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "max": 60,
              "min": 0,
              "step": 0.5,
              "style": { "margin": "8px 0" },
              "value": 0
            },
            "events": {
              "component": {
                "onValueChange": {
                  "script": "    rawVal = int(event.value * 10)\n    system.tag.writeBlocking(['[default]Conveyor/VFD_FreqSetpoint_Raw'], [rawVal])\n"
                }
              }
            },
            "type": "ia.input.slider"
          },
          {
            "meta": { "name": "FreqNumeric" },
            "position": { "basis": "52px", "shrink": 0 },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "tagPath": "[default]Conveyor/VFD_Setpoint_Hz",
                    "bidirectional": false
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "max": 60,
              "min": 0,
              "placeholder": "0.0",
              "style": {
                "color": "#FFFFFF",
                "fontSize": "20px",
                "margin": "8px 0",
                "width": "200px"
              },
              "suffix": " Hz",
              "value": 0
            },
            "events": {
              "component": {
                "onValueChange": {
                  "script": "    rawVal = int(event.value * 10)\n    system.tag.writeBlocking(['[default]Conveyor/VFD_FreqSetpoint_Raw'], [rawVal])\n"
                }
              }
            },
            "type": "ia.input.numeric"
          },
          {
            "meta": { "name": "SetpointReadback" },
            "position": { "basis": "auto" },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "'Current setpoint: ' + format({[default]Conveyor/VFD_Setpoint_Hz}, '#0.0') + ' Hz   (raw: ' + toStr({[default]Conveyor/VFD_FreqSetpoint_Raw}) + ')'"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#00C851",
                "fontSize": "15px",
                "marginTop": "8px"
              },
              "text": "Current setpoint: 0.0 Hz   (raw: 0)"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": { "name": "SetpointPanel" },
        "position": { "basis": "200px", "shrink": 0 },
        "props": {
          "direction": "column",
          "style": {
            "backgroundColor": "#2a2a2a",
            "borderRadius": "8px",
            "margin": "8px 16px",
            "padding": "20px 24px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "script": "    system.tag.writeBlocking(['[default]Conveyor/VFD_CmdWord'], [18])\n"
                }
              }
            },
            "meta": { "name": "FwdButton" },
            "position": { "basis": "auto", "grow": 1 },
            "props": {
              "style": {
                "backgroundColor": "#28A745",
                "border": "none",
                "borderRadius": "8px",
                "color": "#FFFFFF",
                "fontSize": "18px",
                "fontWeight": "bold",
                "height": "80px",
                "letterSpacing": "2px",
                "margin": "8px"
              },
              "text": "▶  FWD RUN"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "script": "    system.tag.writeBlocking(['[default]Conveyor/VFD_CmdWord'], [1])\n"
                }
              }
            },
            "meta": { "name": "StopButton" },
            "position": { "basis": "auto", "grow": 1 },
            "props": {
              "style": {
                "backgroundColor": "#FF4444",
                "border": "none",
                "borderRadius": "8px",
                "color": "#FFFFFF",
                "fontSize": "18px",
                "fontWeight": "bold",
                "height": "80px",
                "letterSpacing": "2px",
                "margin": "8px"
              },
              "text": "■  STOP"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "script": "    system.tag.writeBlocking(['[default]Conveyor/VFD_CmdWord'], [20])\n"
                }
              }
            },
            "meta": { "name": "RevButton" },
            "position": { "basis": "auto", "grow": 1 },
            "props": {
              "style": {
                "backgroundColor": "#FFBB33",
                "border": "none",
                "borderRadius": "8px",
                "color": "#111111",
                "fontSize": "18px",
                "fontWeight": "bold",
                "height": "80px",
                "letterSpacing": "2px",
                "margin": "8px"
              },
              "text": "◀  REV RUN"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": { "name": "ButtonRow" },
        "position": { "basis": "100px", "shrink": 0 },
        "props": {
          "direction": "row",
          "style": { "margin": "8px 16px" },
          "wrap": "nowrap"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": { "name": "CmdNote" },
            "position": { "basis": "auto" },
            "props": {
              "style": {
                "color": "#666666",
                "fontSize": "12px",
                "padding": "8px 16px"
              },
              "text": "FWD=0x0012(18)  REV=0x0014(20)  STOP=0x0001(1)  →  HR400115 (VFD_CmdWord)  |  Setpoint ×10 → HR400116"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": { "name": "CmdNoteRow" },
        "position": { "basis": "40px", "shrink": 0 },
        "props": {
          "align": "center",
          "direction": "row",
          "style": {
            "borderTop": "1px solid #333333",
            "margin": "8px 12px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": { "name": "root" },
    "position": { "basis": "auto" },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#1a1a1a",
        "height": "100%",
        "padding": "8px"
      }
    },
    "type": "ia.container.flex"
  }
}
