{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 800,
      "width": 1280
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": { "name": "Title" },
            "position": { "basis": "auto" },
            "props": {
              "style": {
                "color": "#FFFFFF",
                "fontSize": "22px",
                "fontWeight": "bold",
                "letterSpacing": "3px",
                "padding": "8px 16px"
              },
              "text": "MIRA ALERT HISTORY"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": { "name": "Header" },
        "position": { "basis": "48px", "shrink": 0 },
        "props": {
          "align": "center",
          "direction": "row",
          "style": {
            "backgroundColor": "#111111"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": { "name": "AlertTable" },
            "position": { "basis": "auto", "grow": 1 },
            "props": {
              "columns": [
                {
                  "field": "created_at",
                  "header": "TIMESTAMP",
                  "width": 180
                },
                {
                  "field": "asset_id",
                  "header": "ASSET",
                  "width": 120
                },
                {
                  "field": "detection_type",
                  "header": "TYPE",
                  "width": 160
                },
                {
                  "field": "severity",
                  "header": "SEVERITY",
                  "width": 100
                },
                {
                  "field": "message",
                  "header": "MESSAGE"
                }
              ],
              "data": {
                "columnNames": ["created_at", "asset_id", "detection_type", "severity", "message"],
                "columnTypes": ["str", "str", "str", "str", "str"],
                "rows": []
              },
              "rowHeight": 36,
              "style": {
                "backgroundColor": "#2a2a2a",
                "color": "#FFFFFF",
                "fontSize": "13px"
              }
            },
            "type": "ia.display.table"
          }
        ],
        "meta": { "name": "Content" },
        "position": { "basis": "1", "grow": 1 },
        "props": {
          "direction": "column",
          "style": {
            "padding": "16px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": { "name": "Note" },
            "position": { "basis": "auto" },
            "props": {
              "style": {
                "color": "#666666",
                "fontSize": "12px",
                "padding": "8px 16px"
              },
              "text": "Alerts are detected by Mira's FSM monitor. Configure thresholds in factorylm.properties."
            },
            "type": "ia.display.label"
          }
        ],
        "meta": { "name": "Footer" },
        "position": { "basis": "40px", "shrink": 0 },
        "props": {
          "align": "center",
          "direction": "row",
          "style": {
            "borderTop": "1px solid #333333",
            "margin": "8px 12px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": { "name": "root" },
    "position": { "basis": "auto" },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#1a1a1a",
        "height": "100%",
        "padding": "8px"
      }
    },
    "type": "ia.container.flex"
  }
}
