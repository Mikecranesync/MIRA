                },
                "type": "ia.display.label"
              },
              {
                "events": {
                  "component": {
                    "onFileReceived": {
                      "script": "filename = event.file.name\nasset_id = \"conveyor_demo\"\nimport java.io.File as File\nsave_dir = system.util.getProperty(\"user.dir\") + \"/data/factorylm/docs/\" + asset_id\nFile(save_dir).mkdirs()\nsave_path = save_dir + \"/\" + filename\nevent.file.copyTo(save_path)\nimport urllib2, json\npayload = json.dumps({\"filename\": filename, \"asset_id\": asset_id, \"path\": save_path})\nreq = urllib2.Request(\"http://localhost:5000/ingest\", payload, {\"Content-Type\": \"application/json\"})\ntry:\n    urllib2.urlopen(req, timeout=30)\n    system.perspective.print(\"Document '%s' queued for ingestion\" % filename)\nexcept Exception as e:\n    system.perspective.print(\"Ingest failed: %s\" % str(e))\n"
                    }
                  }
                },
                "meta": { "name": "FileUpload" },
                "position": { "basis": "auto", "grow": 1 },
                "props": {
                  "acceptedFiles": ".pdf,.docx,.txt",
                  "maxFileSize": 20971520,
                  "style": {
                    "color": "#FFFFFF"
                  }
                },
