# mira-bots — Bot configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
OPENWEBUI_BASE_URL=http://mira-core:8080
OPENWEBUI_API_KEY=
MCP_REST_API_KEY=
KNOWLEDGE_COLLECTION_ID=
VISION_MODEL=qwen2.5vl:7b
GLM_OCR_MODEL=glm-ocr:latest
MAX_VISION_PX=512
INGEST_SERVICE_URL=http://mira-ingest:8001

# Slack bot (Socket Mode — no public webhook needed)
# Create app at https://api.slack.com/apps, enable Socket Mode, add scopes below
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
# Optional: comma-separated channel IDs to restrict @mention responses
# Leave blank to allow all channels
SLACK_ALLOWED_CHANNELS=

# Telegram Test Harness
# Get API_ID and API_HASH from https://my.telegram.org (API development tools)
TELEGRAM_TEST_API_ID=
TELEGRAM_TEST_API_HASH=
TELEGRAM_TEST_PHONE=
TELEGRAM_BOT_USERNAME=@MIRABot
# Chat ID of the conversation between test account and bot — auto-populated by setup_v2.py --step3
TELEGRAM_TEST_CHAT_ID=
