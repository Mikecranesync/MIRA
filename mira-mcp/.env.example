# mira-mcp — FastMCP server configuration
# Path to shared mira.db directory (same as mira-bridge)
MIRA_DB_PATH=../mira-bridge/data
# REST API key for :8001 Bearer token auth
MCP_REST_API_KEY=
# Retrieval backend: "openwebui" (default, no change) or "openviking" (filesystem vector store)
RETRIEVAL_BACKEND=openwebui
# Tenant ID for OpenViking store scoping (reuse MIRA_TENANT_ID from Doppler)
MIRA_TENANT_ID=
# Filesystem path for OpenViking store (inside container)
VIKING_STORE_PATH=/mira-db/viking
