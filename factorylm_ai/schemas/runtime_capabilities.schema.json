{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factorylm_ai/schemas/runtime_capabilities.schema.json",
  "title": "RuntimeCapabilities",
  "description": "factorylm.runtime-capabilities.v1 — the machine-readable capability report (PrintSense Provider & OCR Hardening, ADR-0031 FR-1). Written at startup/readiness time; consumed by healthchecks, Print of the Day, benchmark runners, and reports. Must never contain secret VALUES — key_present is the only credential fact allowed. Written within the minimal schema subset of factorylm_ai/schemas/validate.py.",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "enum": ["factorylm.runtime-capabilities.v1"] },
    "environment": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "git_sha": { "type": ["string", "null"] },
    "git_dirty": { "type": ["boolean", "null"] },
    "image_digest": { "type": ["string", "null"] },
    "provider": {
      "type": "object",
      "properties": {
        "requested": { "type": "string", "minLength": 1 },
        "resolved": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "key_present": { "type": "boolean" },
        "network_enabled": { "type": "boolean" },
        "text_probe": { "type": "string", "enum": ["ok", "failed", "skipped"] },
        "vision_probe": { "type": "string", "enum": ["ok", "failed", "skipped"] }
      },
      "required": ["requested", "resolved", "model", "key_present", "network_enabled", "text_probe", "vision_probe"],
      "additionalProperties": false
    },
    "ocr": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "available": { "type": "boolean" },
        "tesseract_version": { "type": ["string", "null"] },
        "pytesseract_version": { "type": ["string", "null"] }
      },
      "required": ["required", "available", "tesseract_version", "pytesseract_version"],
      "additionalProperties": false
    },
    "judge": {
      "type": "object",
      "properties": {
        "provider_policy": { "type": "string", "minLength": 1 },
        "configured": { "type": "boolean" }
      },
      "required": ["provider_policy", "configured"],
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Typed codes from factorylm_ai.capability_codes for every failed requirement. Empty when verdict is 'ready'."
    },
    "verdict": { "type": "string", "enum": ["ready", "degraded", "not_ready"] }
  },
  "required": ["schema", "environment", "generated_at", "git_sha", "git_dirty", "provider", "ocr", "judge", "errors", "verdict"],
  "additionalProperties": true,
  "examples": [
    {
      "schema": "factorylm.runtime-capabilities.v1",
      "environment": "staging",
      "generated_at": "2026-07-21T22:00:00Z",
      "git_sha": "fd8486378b4ceb166a25985eb3a1b6a8d0756f59",
      "git_dirty": false,
      "image_digest": null,
      "provider": {
        "requested": "together",
        "resolved": "together",
        "model": "MiniMaxAI/MiniMax-M3",
        "key_present": true,
        "network_enabled": true,
        "text_probe": "ok",
        "vision_probe": "ok"
      },
      "ocr": {
        "required": true,
        "available": true,
        "tesseract_version": "5.3.0",
        "pytesseract_version": "0.3.13"
      },
      "judge": { "provider_policy": "approved_free", "configured": true },
      "errors": [],
      "verdict": "ready"
    }
  ]
}
