{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factorylm_ai/schemas/task_outputs/m03_output.schema.json",
  "title": "M03PrintRegionExtractOutput",
  "description": "ZTA task M03 (electrical print region extractor) chat output. Produces CANDIDATE devices/terminals/wires/cross_refs only -- PrintSense owns validation; this schema checks shape, not correctness. Model: google/gemma-3n-E4B-it (Together). Prompt: factorylm_ai/tasks/prompts/m03_print_region_extract_v1.txt.",
  "type": "object",
  "properties": {
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tag": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        },
        "required": ["tag", "kind"],
        "additionalProperties": false
      }
    },
    "terminals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "device": { "type": "string", "minLength": 1 },
          "terminal": { "type": "string", "minLength": 1 }
        },
        "required": ["device", "terminal"],
        "additionalProperties": false
      }
    },
    "wires": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "number": { "type": "string", "minLength": 1 }
        },
        "required": ["from", "to", "number"],
        "additionalProperties": false
      }
    },
    "cross_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_sheet": { "type": "string", "minLength": 1 },
          "ref": { "type": "string", "minLength": 1 }
        },
        "required": ["from_sheet", "ref"],
        "additionalProperties": false
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["devices", "terminals", "wires", "cross_refs", "confidence"],
  "additionalProperties": false,
  "examples": [
    {
      "devices": [{ "tag": "K1", "kind": "relay_coil" }],
      "terminals": [{ "device": "K1", "terminal": "A1" }],
      "wires": [{ "from": "K1:A1", "to": "X4:17", "number": "51" }],
      "cross_refs": [{ "from_sheet": "6", "ref": "2.5" }],
      "confidence": 0.6
    },
    {
      "devices": [{ "tag": "F1", "kind": "fuse" }],
      "terminals": [{ "device": "F1", "terminal": "1" }],
      "wires": [{ "from": "F1:1", "to": "X3:9", "number": "12" }],
      "cross_refs": [{ "from_sheet": "3", "ref": "15.7" }],
      "confidence": 0.7
    },
    {
      "devices": [],
      "terminals": [],
      "wires": [],
      "cross_refs": [],
      "confidence": 0.2
    }
  ]
}
