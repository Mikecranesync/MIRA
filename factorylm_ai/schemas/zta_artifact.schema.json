{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factorylm_ai/schemas/zta_artifact.schema.json",
  "title": "ZtaArtifact",
  "description": "One row in the append-only ZTA artifact registry (factorylm_ai/data/registry.jsonl, latest-row-wins). Mirrors factorylm_ai.registry.ZtaArtifact exactly, field for field. runtime_allowed=true is only ever schema-valid when review_status=='approved' AND benchmark_status=='pass' — that gate is enforced in registry.py (fail closed), not expressible in this schema alone.",
  "type": "object",
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1, "description": "e.g. prompt_version, adapter, task_spec, schema_version." },
    "version": { "type": "string", "minLength": 1 },
    "source_interaction_ids": { "type": "array", "items": { "type": "string" } },
    "source_file_hashes": { "type": "array", "items": { "type": "string" } },
    "tenant_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "review_status": {
      "type": "string",
      "enum": ["draft", "approved", "rejected", "superseded"]
    },
    "benchmark_status": {
      "type": "string",
      "enum": ["untested", "pass", "fail", "regression"]
    },
    "runtime_allowed": { "type": "boolean" },
    "metadata": {
      "type": "object",
      "description": "Optional artifact-specific provenance. Adapter artifacts record Together job id, base model, output model, dataset version, and hyperparameters here.",
      "additionalProperties": true
    }
  },
  "required": [
    "artifact_id", "artifact_type", "version",
    "source_interaction_ids", "source_file_hashes",
    "tenant_id", "created_at", "created_by",
    "review_status", "benchmark_status", "runtime_allowed"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "artifact_id": "m05_intent_router_v1",
      "artifact_type": "prompt_version",
      "version": "1",
      "source_interaction_ids": ["int_0001", "int_0002"],
      "source_file_hashes": [],
      "tenant_id": null,
      "created_at": "2026-07-19T00:00:00Z",
      "created_by": "claude",
      "review_status": "draft",
      "benchmark_status": "untested",
      "runtime_allowed": false
    },
    {
      "artifact_id": "factorylm_intent_router",
      "artifact_type": "adapter",
      "version": "ft-123",
      "source_interaction_ids": ["int_0001", "int_0002", "int_0003"],
      "source_file_hashes": ["9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"],
      "tenant_id": null,
      "created_at": "2026-07-19T00:20:00Z",
      "created_by": "mike",
      "review_status": "approved",
      "benchmark_status": "pass",
      "runtime_allowed": true
    }
  ]
}
