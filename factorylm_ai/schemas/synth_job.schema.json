{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factorylm_ai/schemas/synth_job.schema.json",
  "title": "SyntheticFlywheelJob",
  "description": "One synthetic-interaction-flywheel job (addendum §12 + review fixes). The durable per-job provenance record: case vs execution identity, FSM stage/status, attempt/lease/reconciliation counters, and the content-address hashes of every stage's input/output. EVERY persisted field is declared and additionalProperties is false; drift between this schema, the JobRecord dataclass, and the SQLite columns is CI-tested. Written in the minimal schema subset of factorylm_ai/schemas/validate.py.",
  "type": "object",
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "case_key": { "type": "string", "minLength": 1 },
    "execution_key": { "type": "string", "minLength": 1 },
    "case_version": { "type": ["string", "null"] },
    "supersedes_case_key": { "type": ["string", "null"] },
    "reconciliation_count": { "type": "integer", "minimum": 0 },
    "source_type": {
      "type": "string",
      "enum": ["real_user", "owner_generated", "synthetic_benchmark", "simulated_fault", "public_document_case"]
    },
    "source_id": { "type": "string", "minLength": 1 },
    "document_lineage_key": { "type": "string", "minLength": 1 },
    "target_surface": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": [
        "DISCOVERED", "SOURCE_ELIGIBILITY_PENDING", "INELIGIBLE", "QUESTION_PENDING",
        "QUESTION_READY", "TARGET_RUN_PENDING", "TARGET_RUN_COMPLETE", "CRITIC_PENDING",
        "CRITIC_COMPLETE", "RECONCILIATION_PENDING", "HUMAN_REVIEW", "APPROVED_GOLD",
        "APPROVED_EVAL_ONLY", "REJECTED", "EXPORTED", "DEAD_LETTER"
      ]
    },
    "status": { "type": "string", "enum": ["pending", "in_progress", "done"] },
    "attempt_count": { "type": "integer", "minimum": 0 },
    "idempotency_key": { "type": ["string", "null"] },
    "input_hash": { "type": ["string", "null"] },
    "evidence_hash": { "type": ["string", "null"] },
    "answer_key_hash": { "type": ["string", "null"] },
    "blind_response_hash": { "type": ["string", "null"] },
    "critic_output_hash": { "type": ["string", "null"] },
    "candidate_output_hash": { "type": ["string", "null"] },
    "prompt_version": { "type": ["string", "null"] },
    "model_provider": { "type": ["string", "null"] },
    "model_id": { "type": ["string", "null"] },
    "model_version": { "type": ["string", "null"] },
    "rights_status": { "type": ["string", "null"] },
    "split": { "type": ["string", "null"] },
    "created_at": { "type": ["number", "null"] },
    "started_at": { "type": ["number", "null"] },
    "finished_at": { "type": ["number", "null"] },
    "lease_expires_at": { "type": ["number", "null"] },
    "error_code": { "type": ["string", "null"] },
    "error_detail": { "type": ["string", "null"] },
    "labels": { "type": "object" }
  },
  "required": [
    "job_id", "case_id", "case_key", "execution_key", "reconciliation_count",
    "source_type", "source_id", "document_lineage_key", "target_surface",
    "stage", "status", "attempt_count"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "job_id": "0123456789abcdef0123456789abcdef",
      "case_id": "synth-ps-000123",
      "case_key": "case_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "execution_key": "exec_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "case_version": "v1",
      "supersedes_case_key": null,
      "reconciliation_count": 0,
      "source_type": "public_document_case",
      "source_id": "rockwell-509-nema-starter#p12",
      "document_lineage_key": "gi-wd005",
      "target_surface": "printsense",
      "stage": "DISCOVERED",
      "status": "pending",
      "attempt_count": 0,
      "idempotency_key": "exec_bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "input_hash": null,
      "evidence_hash": null,
      "answer_key_hash": null,
      "blind_response_hash": null,
      "critic_output_hash": null,
      "candidate_output_hash": null,
      "prompt_version": null,
      "model_provider": null,
      "model_id": null,
      "model_version": "base",
      "rights_status": "training_allowed",
      "split": "train",
      "created_at": 1753000000.0,
      "started_at": null,
      "finished_at": null,
      "lease_expires_at": null,
      "error_code": null,
      "error_detail": null,
      "labels": {}
    }
  ]
}
