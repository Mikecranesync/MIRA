<modbusServer Version="3.0">
  <!-- Micro820 v5.1.0 Modbus server map (Trends V2). 24 coils + 25 holding registers.
       Supersedes MbSrvConf_v4.xml (23 coils + 17 HRs). Adds the full-GS10-monitoring
       mirrors the ladder populates in v5.1.0 (Micro820_v5.1.0_Program.st):
         HR   400118 vfd_status_word   (GS10 0x2101 Status Monitor 2 bits)
         HR   400119 vfd_fault_code    (GS10 0x2100 low byte = active fault)
         HR   400120 vfd_warn_code     (GS10 0x2100 high byte = active warning)
         HR   400121 vfd_freq_cmd      (GS10 0x2102 commanded frequency)
         HR   400122 vfd_torque        (GS10 0x210B output torque, % x10)
         HR   400123 vfd_motor_rpm     (GS10 0x210C actual shaft speed, rpm)
         HR   400124 vfd_power         (GS10 0x210F output power, kW x1000)
         HR   400125 vfd_last_fault    (PLC-latched last nonzero fault code)
         coil 000024 last_fault_clear  (operator clear for the last-fault latch)
       Historian mapping: pymodbus HR offset = CCW address - 400101 + 100, i.e.
       400118 -> offset 117 (see plc/conv_simple_anomaly/live_logger.py HR_SPECS).
       dataType MUST match the variable's declared type in CCW: the vfd_* registers
       are declared Word in Conv_Simple_1.8 (per the deployed MbSrvConf.xml); the
       old v4 map said Int for those, which never shipped. Verify on import.
       Variable names MUST match the ladder globals exactly. New variables: see
       plc/CCW_VARIABLES_v5.1.0_DELTA.md. Version="3.0" is the CCW MbSrvConf schema
       version, not the ladder version - do not bump. -->
  <modbusRegister name="COILS">
    <mapping variable="motor_running" parent="Micro820" dataType="Bool" address="000001">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="conveyor_running" parent="Micro820" dataType="Bool" address="000002">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
