<modbusServer Version="2.0">
  <!-- Conv_Simple_1.8 Modbus server map, V1.9 (Trends V2).
       SURGICAL SUPERSET of the deployed map (Version 2.0, 13 coils + 5 HRs):
       every live entry is preserved verbatim, and ONLY the new full-GS10
       monitoring registers are appended. We deliberately do NOT add the
       v4-lineage variables (conveyor_running, fault_alarm, system_ready,
       dir_*, motor_speed, conv_state, vfd_poll_step, ...) which exist in
       the old plc/MbSrvConf_v4.xml but may NOT exist as globals in the live
       1.8 project, and referencing a non-existent variable fails the import.
       New, written by Prog_init V1.9 (plc/Prog_init_ConvSimple_v1.9.st):
         coil 000024 last_fault_clear  (operator clear for the latch; HMI-write)
         HR   400118 vfd_status_word   (0x2101 status bits)
         HR   400119 vfd_fault_code    (0x2100 low byte = active fault)
         HR   400120 vfd_warn_code     (0x2100 high byte = active warning)
         HR   400121 vfd_freq_cmd      (0x2102 freq command echo)
         HR   400122 vfd_torque        (0x210B torque, 0.1 %)
         HR   400123 vfd_motor_rpm     (0x210C motor speed, rpm)
         HR   400124 vfd_power         (0x210F output power, 0.001 kW)
         HR   400125 vfd_last_fault    (PLC-latched last nonzero fault)
       Historian pymodbus offset = CCW address - 400001 (400118 -> 117),
       matching plc/conv_simple_anomaly/live_logger.py HR_SPECS 117..124.
       Version="2.0" matches the deployed file's CCW schema version (do not
       bump). CCW must be CLOSED when deploy_modbus_map.py drops this in. -->
  <modbusRegister name="COILS">
    <mapping variable="motor_running" parent="Micro820" dataType="Bool" address="000001">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
