PROGRAM ConveyorPhase1
VAR_INPUT
    DI_02 : BOOL;    (* E-stop NC contact - healthy = TRUE *)
    DI_00 : BOOL;    (* Direction selector FWD wire *)
    DI_01 : BOOL;    (* Direction selector REV wire *)
END_VAR

VAR_OUTPUT
    DO_02 : BOOL;    (* Safety contactor Q1 *)
    dir_fwd : BOOL;
    dir_rev : BOOL;
END_VAR

VAR
    e_stop_active : BOOL;
    vfd_cmd : INT;
    vfd_freq : INT;
    poll_timer : TON;
END_VAR

(* Section 1: E-stop - NC contact, open = tripped *)
e_stop_active := NOT DI_02;

(* Section 2: Safety contactor energized when e-stop healthy *)
DO_02 := NOT e_stop_active;

(* Section 3: Direction decode from 2-wire selector *)
dir_fwd := DI_00 AND NOT DI_01;
dir_rev := NOT DI_00 AND DI_01;

(* Section 4: VFD command word - 1=STOP 18=FWD+RUN 20=REV+RUN *)
IF dir_fwd AND NOT e_stop_active THEN
    vfd_cmd := 18;
ELSIF dir_rev AND NOT e_stop_active THEN
    vfd_cmd := 20;
ELSE
    vfd_cmd := 1;
END_IF;

(* Section 5: Fixed frequency 30.0 Hz = 300 in Modbus units *)
vfd_freq := 300;

(* Section 6: 500ms poll pulse for Modbus writes *)
poll_timer(IN := NOT poll_timer.Q, PT := T#500ms);

END_PROGRAM
