{
  "base": {
    "style": {
      "backgroundImage": "repeating-linear-gradient(115deg, rgba(57,211,83,0) 0px, rgba(57,211,83,0) 18px, rgba(57,211,83,0.65) 18px, rgba(57,211,83,0.65) 34px)",
      "borderRadius": "4px"
    },
    "animation": {
      "duration": "1.1s",
      "iterationCount": "infinite",
      "timingFunction": "linear",
      "direction": "reverse",
      "keyframes": {
        "0%": { "backgroundPosition": "0px 0px" },
        "100%": { "backgroundPosition": "34px 0px" }
      }
    }
  }
