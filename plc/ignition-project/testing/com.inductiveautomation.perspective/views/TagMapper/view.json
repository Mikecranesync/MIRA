{
  "custom": {
    "selRole": "vfd/vfd101/freq",
    "selSearch": "",
    "selTag": "",
    "selDivisor": 100,
    "showOptional": false,
    "status": ""
  },
  "params": {
    "assetId": "conveyor",
    "pollMs": 2000
  },
  "props": { "defaultSize": { "width": 1360, "height": 980 } },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": { "direction": "column", "style": { "backgroundColor": "#0d1117", "height": "100%" } },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "header" },
        "position": { "basis": "54px", "shrink": 0 },
        "props": { "direction": "row", "alignItems": "center", "style": { "backgroundColor": "#161b22", "borderBottom": "1px solid #30363d", "padding": "0 16px", "gap": "14px" } },
        "children": [
          { "type": "ia.display.label", "meta": { "name": "brand" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "VFD ANALYZER — TAG SETUP", "style": { "color": "#e6edf3", "fontSize": "16px", "fontWeight": 700, "letterSpacing": "0.08em" } } },
          { "type": "ia.display.label", "meta": { "name": "assetLbl" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "asset", "style": { "color": "#8b949e", "fontSize": "13px" } }, "propConfig": { "props.text": { "binding": { "type": "expr", "config": { "expression": "\"asset: \" + {view.params.assetId}" } } } } },
          {
            "type": "ia.display.label", "meta": { "name": "gatePill" }, "position": { "grow": 1, "shrink": 1 },
            "props": { "text": "…", "style": { "color": "#ffffff", "backgroundColor": "#30363d", "fontSize": "14px", "fontWeight": 700, "borderRadius": "14px", "padding": "5px 14px", "textAlign": "center" } },
            "propConfig": {
              "props.text": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.gate_text\", {view.params.pollMs}, {view.params.assetId})" } } },
              "props.style.backgroundColor": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.gate_color\", {view.params.pollMs}, {view.params.assetId})" } } }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "body" },
        "position": { "grow": 1, "shrink": 1 },
        "props": { "direction": "row", "style": { "gap": "12px", "padding": "12px", "overflow": "hidden" } },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "leftCol" },
            "position": { "basis": "480px", "shrink": 0 },
            "props": { "direction": "column", "style": { "gap": "10px", "overflow": "auto" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "leftTitle" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "WHAT TO MAP   —   tap a slot, then pick its tag →", "style": { "color": "#8b949e", "fontSize": "12px", "fontWeight": 700, "letterSpacing": "0.06em" } } },

              {
                "type": "ia.container.flex", "meta": { "name": "slotFreq" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "direction": "column", "style": { "backgroundColor": "#161b22", "border": "2px solid #f0a90e", "borderRadius": "10px", "padding": "14px", "gap": "6px", "cursor": "pointer" } },
                "propConfig": { "props.style.border": { "binding": { "type": "expr", "config": { "expression": "\"2px solid \" + if({view.custom.selRole} = \"vfd/vfd101/freq\", \"#58a6ff\", runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/freq\"))" } } } },
                "events": { "dom": { "onClick": [ { "type": "script", "scope": "G", "config": { "script": "\tself.view.custom.selRole = \"vfd/vfd101/freq\"\n\tself.view.custom.selTag = \"\"\n\tself.view.custom.selSearch = \"\"\n\tself.view.custom.status = \"\"\n\tself.view.custom.selDivisor = mira_setup.slot_divisor(\"vfd/vfd101/freq\", self.view.params.assetId)\n" } } ] } },
                "children": [
                  {
                    "type": "ia.container.flex", "meta": { "name": "freqTop" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "12px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "freqNum" }, "position": { "basis": "34px", "shrink": 0 }, "props": { "text": "1", "style": { "color": "#0d1117", "backgroundColor": "#8b949e", "fontSize": "18px", "fontWeight": 800, "borderRadius": "8px", "textAlign": "center", "padding": "2px 0" } } },
                      { "type": "ia.display.label", "meta": { "name": "freqName" }, "position": { "grow": 1, "shrink": 1 }, "props": { "text": "Output frequency", "style": { "color": "#e6edf3", "fontSize": "19px", "fontWeight": 700 } } },
                      { "type": "ia.display.label", "meta": { "name": "freqUnit" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "Hz", "style": { "color": "#c9d1d9", "backgroundColor": "#21262d", "fontSize": "13px", "fontWeight": 700, "borderRadius": "6px", "padding": "2px 10px" } } },
                      { "type": "ia.display.label", "meta": { "name": "freqReq" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "REQUIRED", "style": { "color": "#f0a90e", "fontSize": "10px", "fontWeight": 700, "letterSpacing": "0.08em" } } }
                    ]
                  },
                  {
                    "type": "ia.display.label", "meta": { "name": "freqStatus" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "text": "…", "style": { "color": "#f0a90e", "fontSize": "15px", "fontWeight": 600, "fontFamily": "Consolas, monospace" } },
                    "propConfig": {
                      "props.text": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_text\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/freq\")" } } },
                      "props.style.color": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/freq\")" } } }
                    }
                  }
                ]
              },

              {
                "type": "ia.container.flex", "meta": { "name": "slotCurrent" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "direction": "column", "style": { "backgroundColor": "#161b22", "border": "2px solid #f0a90e", "borderRadius": "10px", "padding": "14px", "gap": "6px", "cursor": "pointer" } },
                "propConfig": { "props.style.border": { "binding": { "type": "expr", "config": { "expression": "\"2px solid \" + if({view.custom.selRole} = \"vfd/vfd101/current_a\", \"#58a6ff\", runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/current_a\"))" } } } },
                "events": { "dom": { "onClick": [ { "type": "script", "scope": "G", "config": { "script": "\tself.view.custom.selRole = \"vfd/vfd101/current_a\"\n\tself.view.custom.selTag = \"\"\n\tself.view.custom.selSearch = \"\"\n\tself.view.custom.status = \"\"\n\tself.view.custom.selDivisor = mira_setup.slot_divisor(\"vfd/vfd101/current_a\", self.view.params.assetId)\n" } } ] } },
                "children": [
                  {
                    "type": "ia.container.flex", "meta": { "name": "curTop" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "12px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "curNum" }, "position": { "basis": "34px", "shrink": 0 }, "props": { "text": "2", "style": { "color": "#0d1117", "backgroundColor": "#8b949e", "fontSize": "18px", "fontWeight": 800, "borderRadius": "8px", "textAlign": "center", "padding": "2px 0" } } },
                      { "type": "ia.display.label", "meta": { "name": "curName" }, "position": { "grow": 1, "shrink": 1 }, "props": { "text": "Output current", "style": { "color": "#e6edf3", "fontSize": "19px", "fontWeight": 700 } } },
                      { "type": "ia.display.label", "meta": { "name": "curUnit" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "A", "style": { "color": "#c9d1d9", "backgroundColor": "#21262d", "fontSize": "13px", "fontWeight": 700, "borderRadius": "6px", "padding": "2px 10px" } } },
                      { "type": "ia.display.label", "meta": { "name": "curReq" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "REQUIRED", "style": { "color": "#f0a90e", "fontSize": "10px", "fontWeight": 700, "letterSpacing": "0.08em" } } }
                    ]
                  },
                  {
                    "type": "ia.display.label", "meta": { "name": "curStatus" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "text": "…", "style": { "color": "#f0a90e", "fontSize": "15px", "fontWeight": 600, "fontFamily": "Consolas, monospace" } },
                    "propConfig": {
                      "props.text": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_text\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/current_a\")" } } },
                      "props.style.color": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/current_a\")" } } }
                    }
                  }
                ]
              },

              {
                "type": "ia.container.flex", "meta": { "name": "slotFault" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "direction": "column", "style": { "backgroundColor": "#161b22", "border": "2px solid #f0a90e", "borderRadius": "10px", "padding": "14px", "gap": "6px", "cursor": "pointer" } },
                "propConfig": { "props.style.border": { "binding": { "type": "expr", "config": { "expression": "\"2px solid \" + if({view.custom.selRole} = \"vfd/vfd101/fault_code\", \"#58a6ff\", runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/fault_code\"))" } } } },
                "events": { "dom": { "onClick": [ { "type": "script", "scope": "G", "config": { "script": "\tself.view.custom.selRole = \"vfd/vfd101/fault_code\"\n\tself.view.custom.selTag = \"\"\n\tself.view.custom.selSearch = \"\"\n\tself.view.custom.status = \"\"\n\tself.view.custom.selDivisor = mira_setup.slot_divisor(\"vfd/vfd101/fault_code\", self.view.params.assetId)\n" } } ] } },
                "children": [
                  {
                    "type": "ia.container.flex", "meta": { "name": "fltTop" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "12px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "fltNum" }, "position": { "basis": "34px", "shrink": 0 }, "props": { "text": "3", "style": { "color": "#0d1117", "backgroundColor": "#8b949e", "fontSize": "18px", "fontWeight": 800, "borderRadius": "8px", "textAlign": "center", "padding": "2px 0" } } },
                      { "type": "ia.display.label", "meta": { "name": "fltName" }, "position": { "grow": 1, "shrink": 1 }, "props": { "text": "Fault code", "style": { "color": "#e6edf3", "fontSize": "19px", "fontWeight": 700 } } },
                      { "type": "ia.display.label", "meta": { "name": "fltUnit" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "code", "style": { "color": "#c9d1d9", "backgroundColor": "#21262d", "fontSize": "13px", "fontWeight": 700, "borderRadius": "6px", "padding": "2px 10px" } } },
                      { "type": "ia.display.label", "meta": { "name": "fltReq" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "REQUIRED", "style": { "color": "#f0a90e", "fontSize": "10px", "fontWeight": 700, "letterSpacing": "0.08em" } } }
                    ]
                  },
                  {
                    "type": "ia.display.label", "meta": { "name": "fltStatus" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "text": "…", "style": { "color": "#f0a90e", "fontSize": "15px", "fontWeight": 600, "fontFamily": "Consolas, monospace" } },
                    "propConfig": {
                      "props.text": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_text\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/fault_code\")" } } },
                      "props.style.color": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.slot_color\", {view.params.pollMs}, {view.params.assetId}, \"vfd/vfd101/fault_code\")" } } }
                    }
                  }
                ]
              },

              {
                "type": "ia.input.button", "meta": { "name": "optToggle" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "text": "+ Add optional signals (15 more)", "style": { "backgroundColor": "#21262d", "color": "#c9d1d9", "fontSize": "13px", "fontWeight": 600, "borderRadius": "8px", "border": "1px solid #30363d", "padding": "8px" } },
                "propConfig": { "props.text": { "binding": { "type": "expr", "config": { "expression": "if({view.custom.showOptional}, \"− Hide optional signals\", \"+ Add optional signals (15 more)\")" } } } },
                "events": { "component": { "onActionPerformed": { "type": "script", "scope": "G", "config": { "script": "\tself.view.custom.showOptional = not self.view.custom.showOptional\n" } } } }
              },
              {
                "type": "ia.container.flex", "meta": { "name": "optPanel" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "direction": "column", "visible": false, "style": { "backgroundColor": "#161b22", "border": "1px solid #30363d", "borderRadius": "8px", "padding": "12px", "gap": "8px" } },
                "propConfig": { "props.visible": { "binding": { "type": "property", "config": { "path": "view.custom.showOptional" } } } },
                "children": [
                  { "type": "ia.display.label", "meta": { "name": "optHint" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "Pick an optional / recommended signal — then map its tag the same way →", "style": { "color": "#8b949e", "fontSize": "12px" } } },
                  {
                    "type": "ia.input.dropdown", "meta": { "name": "optDrop" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "value": "" },
                    "propConfig": {
                      "props.value": { "binding": { "type": "property", "config": { "path": "view.custom.selRole" }, "bidirectional": true } },
                      "props.options": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.optional_role_options\", 0)" } } }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "rightCol" },
            "position": { "grow": 1, "shrink": 1 },
            "props": { "direction": "column", "style": { "gap": "8px", "overflow": "hidden" } },
            "children": [
              { "type": "ia.display.label", "meta": { "name": "pickTitle" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "TAP THE TAG THAT FITS", "style": { "color": "#e6edf3", "fontSize": "15px", "fontWeight": 700, "letterSpacing": "0.04em" } } },
              {
                "type": "ia.display.label", "meta": { "name": "pickSub" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "text": "…", "style": { "color": "#58a6ff", "fontSize": "14px", "fontWeight": 600 } },
                "propConfig": { "props.text": { "binding": { "type": "expr", "config": { "expression": "\"for:  \" + runScript(\"mira_setup.role_display\", 0, {view.custom.selRole}) + \"      (showing \" + runScript(\"mira_setup.role_typehint\", 0, {view.custom.selRole}) + \")\"" } } } }
              },
              {
                "type": "ia.input.text-field", "meta": { "name": "searchField" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "text": "", "placeholder": "search tag name…  (optional — list is already filtered to fitting types)" },
                "propConfig": { "props.text": { "binding": { "type": "property", "config": { "path": "view.custom.selSearch" }, "bidirectional": true } } }
              },
              {
                "type": "ia.display.table", "meta": { "name": "candTable" }, "position": { "grow": 1, "shrink": 1 },
                "props": {
                  "data": [],
                  "columns": [
                    { "field": "tag", "header": { "title": "Tag  (tap a row to choose)" }, "align": "left" },
                    { "field": "value", "header": { "title": "Live value" }, "align": "left" },
                    { "field": "quality", "header": { "title": "Quality" }, "align": "left" },
                    { "field": "path", "header": { "title": "Full path" }, "align": "left" }
                  ],
                  "rows": { "pageSize": 0 },
                  "style": { "border": "1px solid #30363d", "borderRadius": "8px" }
                },
                "propConfig": {
                  "props.data": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.scan_for_role\", {view.params.pollMs}, \"[default]\", {view.custom.selSearch}, {view.custom.selRole})" } } }
                },
                "events": { "component": { "onRowClick": { "type": "script", "scope": "G", "config": { "script": "\ttry:\n\t\tself.view.custom.selTag = event.value['path']\n\t\tself.view.custom.status = \"\"\n\texcept Exception:\n\t\tpass\n" } } } }
              },
              {
                "type": "ia.container.flex", "meta": { "name": "confirm" }, "position": { "basis": "auto", "shrink": 0 },
                "props": { "direction": "column", "style": { "backgroundColor": "#161b22", "border": "1px solid #30363d", "borderRadius": "8px", "padding": "12px", "gap": "8px" } },
                "children": [
                  {
                    "type": "ia.container.flex", "meta": { "name": "chosenRow" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "10px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "chosenLbl" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "Chosen tag:", "style": { "color": "#8b949e", "fontSize": "13px" } } },
                      {
                        "type": "ia.display.label", "meta": { "name": "chosenVal" }, "position": { "basis": "auto", "shrink": 0 },
                        "props": { "text": "(tap a tag above)", "style": { "color": "#e6edf3", "fontSize": "14px", "fontWeight": 700, "fontFamily": "Consolas, monospace" } },
                        "propConfig": { "props.text": { "binding": { "type": "expr", "config": { "expression": "if(len({view.custom.selTag})>0, {view.custom.selTag}, \"(tap a tag above)\")" } } } }
                      },
                      {
                        "type": "ia.display.label", "meta": { "name": "previewLbl" }, "position": { "grow": 1, "shrink": 1 },
                        "props": { "text": "", "style": { "color": "#58a6ff", "fontSize": "15px", "fontWeight": 700, "fontFamily": "Consolas, monospace", "textAlign": "right" } },
                        "propConfig": { "props.text": { "binding": { "type": "expr", "config": { "expression": "runScript(\"mira_setup.preview\", 1000, {view.custom.selTag}, {view.custom.selDivisor}, {view.custom.selRole})" } } } }
                      }
                    ]
                  },
                  {
                    "type": "ia.container.flex", "meta": { "name": "actionRow" }, "position": { "basis": "auto", "shrink": 0 },
                    "props": { "direction": "row", "alignItems": "center", "style": { "gap": "10px" } },
                    "children": [
                      { "type": "ia.display.label", "meta": { "name": "scaleLbl" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "Scale ÷ (auto)", "style": { "color": "#8b949e", "fontSize": "12px" } } },
                      {
                        "type": "ia.input.numeric-entry-field", "meta": { "name": "scaleField" }, "position": { "basis": "90px", "shrink": 0 },
                        "props": { "value": 100 },
                        "propConfig": { "props.value": { "binding": { "type": "property", "config": { "path": "view.custom.selDivisor" }, "bidirectional": true } } }
                      },
                      {
                        "type": "ia.input.button", "meta": { "name": "useBtn" }, "position": { "grow": 1, "shrink": 1 },
                        "props": { "text": "✓ Use this tag", "enabled": false, "style": { "backgroundColor": "#238636", "color": "#ffffff", "fontSize": "15px", "fontWeight": 700, "borderRadius": "8px", "border": "none", "padding": "10px" } },
                        "propConfig": {
                          "props.enabled": { "binding": { "type": "expr", "config": { "expression": "len({view.custom.selTag})>0" } } },
                          "props.text": { "binding": { "type": "expr", "config": { "expression": "\"✓ Use this tag for  \" + runScript(\"mira_setup.role_display\", 0, {view.custom.selRole})" } } }
                        },
                        "events": { "component": { "onActionPerformed": { "type": "script", "scope": "G", "config": { "script": "\tasset = self.view.params.assetId or \"conveyor\"\n\trole = self.view.custom.selRole\n\ttag = self.view.custom.selTag\n\tdiv = self.view.custom.selDivisor\n\tself.view.custom.status = mira_setup.set_role(asset, role, tag, div)\n\tself.view.custom.selTag = \"\"\n" } } } }
                      },
                      {
                        "type": "ia.input.button", "meta": { "name": "clearBtn" }, "position": { "basis": "130px", "shrink": 0 },
                        "props": { "text": "Clear this role", "style": { "backgroundColor": "#30363d", "color": "#c9d1d9", "fontSize": "13px", "fontWeight": 600, "borderRadius": "8px", "border": "none", "padding": "10px" } },
                        "events": { "component": { "onActionPerformed": { "type": "script", "scope": "G", "config": { "script": "\tself.view.custom.status = mira_setup.clear_role(self.view.params.assetId or \"conveyor\", self.view.custom.selRole)\n" } } } }
                      }
                    ]
                  },
                  { "type": "ia.display.label", "meta": { "name": "statusLbl" }, "position": { "basis": "auto", "shrink": 0 }, "props": { "text": "", "style": { "color": "#8b949e", "fontSize": "13px" } }, "propConfig": { "props.text": { "binding": { "type": "property", "config": { "path": "view.custom.status" } } } } }
                ]
              }
            ]
          }
        ]
      },
      { "type": "ia.display.label", "meta": { "name": "mapLabel" }, "position": { "basis": "20px", "shrink": 0 }, "props": { "text": "YOUR MAP SO FAR   (all signals — read-only)", "style": { "color": "#8b949e", "fontSize": "11px", "fontWeight": 700, "letterSpacing": "0.08em", "padding": "4px 12px 0 12px" } } },
      {
        "type": "ia.display.markdown", "meta": { "name": "mapTable" }, "position": { "basis": "150px", "shrink": 0 },
        "props": { "source": "Loading…", "style": { "backgroundColor": "#0d1117", "color": "#e6edf3", "border": "1px solid #30363d", "borderRadius": "8px", "margin": "0 12px 12px 12px", "padding": "12px", "fontSize": "12px", "overflow": "auto" } },
