{
  "custom": {},
  "params": {
    "assetId": "conveyor",
    "tagFolders": "[default]MIRA_IOCheck/VFD,[default]MIRA_IOCheck/Inputs,[default]MIRA_IOCheck/Outputs,[default]Conveyor",
    "pollMs": 2000,
    "trendUrl": "http://127.0.0.1:8766/viewer/index.html?source=historian"
  },
  "props": {
    "defaultSize": { "width": 1280, "height": 800 }
  },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": {
      "direction": "column",
      "style": { "backgroundColor": "#0d1117", "height": "100%" }
    },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "header" },
        "position": { "basis": "60px", "shrink": 0 },
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": { "backgroundColor": "#161b22", "borderBottom": "1px solid #30363d", "padding": "0 16px", "gap": "14px" }
        },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "brand" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": {
              "text": "MAINTENANCE INTELLIGENCE",
              "style": { "color": "#e6edf3", "fontSize": "16px", "fontWeight": 700, "letterSpacing": "0.08em" }
            }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "statePill" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": {
              "text": "…",
              "style": {
                "color": "#ffffff",
                "backgroundColor": "#30363d",
                "fontSize": "13px",
                "fontWeight": 700,
                "letterSpacing": "0.06em",
                "borderRadius": "13px",
                "padding": "4px 14px"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "runScript(\"mira_diagnose.header_text\", {view.params.pollMs}, {view.params.tagFolders})" }
                }
              },
              "props.style.backgroundColor": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "runScript(\"mira_diagnose.header_color\", {view.params.pollMs}, {view.params.tagFolders})" }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "stateSub" },
            "position": { "grow": 1, "shrink": 1 },
            "props": {
              "text": "",
              "style": { "color": "#8b949e", "fontSize": "13px" }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "runScript(\"mira_diagnose.header_sub\", {view.params.pollMs}, {view.params.tagFolders})" }
                }
              }
            }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "countBadge" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": {
              "text": "",
              "style": { "color": "#c9d1d9", "fontSize": "12px", "fontWeight": 600, "fontFamily": "Consolas, monospace" }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "expr",
                  "config": { "expression": "runScript(\"mira_diagnose.count_text\", {view.params.pollMs}, {view.params.tagFolders})" }
                }
              }
            }
          }
        ]
      },
      {
        "type": "ia.container.flex",
        "meta": { "name": "body" },
        "position": { "grow": 1, "basis": "1" },
        "props": { "direction": "row", "style": { "gap": "0px" } },
        "children": [
          {
            "type": "ia.container.flex",
            "meta": { "name": "feedColumn" },
            "position": { "grow": 1, "basis": "1" },
            "props": { "direction": "column", "style": { "padding": "12px", "gap": "10px" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "feedLabel" },
                "position": { "basis": "20px", "shrink": 0 },
                "props": {
                  "text": "ANOMALY FEED",
                  "style": { "color": "#8b949e", "fontSize": "11px", "fontWeight": 700, "letterSpacing": "0.08em" }
                }
              },
              {
                "type": "ia.container.flex",
                "meta": { "name": "feedScroll" },
                "position": { "grow": 1, "basis": "1" },
                "props": { "direction": "column", "style": { "overflow": "auto", "gap": "8px" } },
                "children": [
                  {
                    "type": "ia.display.flex-repeater",
                    "meta": { "name": "anomalyRepeater" },
                    "position": { "basis": "auto", "shrink": 0 },
                    "props": {
                      "direction": "column",
                      "path": "AnomalyCard",
                      "instances": [],
                      "useDefaultViewHeight": true,
                      "useDefaultViewWidth": false,
                      "elementPosition": { "basis": "auto", "grow": 0, "shrink": 0 },
                      "style": { "gap": "8px", "overflow": "visible" }
                    },
                    "propConfig": {
                      "props.instances": {
                        "binding": {
                          "type": "expr",
                          "config": { "expression": "runScript(\"mira_diagnose.cards_json\", {view.params.pollMs}, {view.params.tagFolders})" }
                        }
                      }
                    }
                  },
                  {
                    "type": "ia.display.label",
                    "meta": { "name": "allClear" },
                    "position": { "basis": "auto", "shrink": 0 },
                    "props": {
                      "text": "✓ No active anomalies — all monitored signals nominal.",
                      "style": { "color": "#3fb950", "fontSize": "13px", "padding": "10px 4px" }
                    },
                    "propConfig": {
                      "meta.visible": {
                        "binding": {
                          "type": "expr",
                          "config": { "expression": "runScript(\"mira_diagnose.count_text\", {view.params.pollMs}, {view.params.tagFolders}) = \"No active anomalies\"" }
                        }
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "ia.container.flex",
            "meta": { "name": "trendColumn" },
            "position": { "basis": "420px", "shrink": 0 },
            "props": { "direction": "column", "style": { "borderLeft": "1px solid #30363d", "backgroundColor": "#161b22" } },
            "children": [
              {
                "type": "ia.display.label",
                "meta": { "name": "trendLabel" },
                "position": { "basis": "28px", "shrink": 0 },
                "props": {
                  "text": "LIVE TRENDS",
                  "style": { "color": "#8b949e", "fontSize": "11px", "fontWeight": 700, "letterSpacing": "0.08em", "padding": "8px 12px 0 12px" }
                }
              },
              {
                "type": "ia.display.iframe",
                "meta": { "name": "trendIframe" },
                "position": { "grow": 1, "basis": "1" },
                "props": {
                  "src": "http://127.0.0.1:8766/viewer/index.html?source=historian",
                  "style": { "border": "none", "height": "100%", "width": "100%" }
                },
                "propConfig": {
                  "props.src": {
                    "binding": { "type": "property", "config": { "path": "view.params.trendUrl" } }
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "footer" },
        "position": { "basis": "28px", "shrink": 0 },
        "props": {
          "text": "Conv_Simple · in-gateway anomaly detection (offline, no cloud) · tap a card to Ask MIRA · FactoryLM",
          "style": { "color": "#6b7480", "fontSize": "11px", "textAlign": "center", "borderTop": "1px solid #30363d", "padding": "5px" }
        }
      }
    ]
  }
}
