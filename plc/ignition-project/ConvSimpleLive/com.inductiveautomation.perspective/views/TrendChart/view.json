{
  "custom": {},
  "params": { "rangeMinutes": 15 },
  "propConfig": { "params.rangeMinutes": { "paramDirection": "input" } },
  "props": { "defaultSize": { "width": 900, "height": 500 } },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": { "direction": "column", "style": { "backgroundColor": "#0d1117", "height": "100%", "gap": "6px", "padding": "6px" } },
    "children": [
      {
        "type": "ia.container.flex",
        "meta": { "name": "controls" },
        "position": { "basis": "32px", "shrink": 0 },
        "props": { "direction": "row", "alignItems": "center", "style": { "gap": "10px" } },
        "children": [
          {
            "type": "ia.display.label",
            "meta": { "name": "rangeLabel" },
            "position": { "basis": "auto", "shrink": 0 },
            "props": { "text": "Range", "style": { "color": "#8b949e", "fontSize": "12px" } }
          },
          {
            "type": "ia.input.dropdown",
            "meta": { "name": "rangePicker" },
            "position": { "basis": "140px", "shrink": 0 },
            "props": {
              "value": 15,
              "options": [
                { "value": 5, "label": "5 min" },
                { "value": 15, "label": "15 min" },
                { "value": 60, "label": "1 hour" },
                { "value": 480, "label": "8 hours" }
              ],
              "style": { "backgroundColor": "#161b22", "color": "#e6edf3", "border": "1px solid #30363d" }
            },
            "propConfig": {
              "props.value": { "binding": { "type": "property", "config": { "path": "view.params.rangeMinutes" }, "bidirectional": true } }
            }
          },
          {
            "type": "ia.display.label",
            "meta": { "name": "rawNote" },
            "position": { "grow": 1, "shrink": 1 },
            "props": { "text": "GS10 drive — raw counts (OutputHz/SetpointHz x100, Current x100, DCBus x10)", "style": { "color": "#6b7480", "fontSize": "11px", "textAlign": "right" } }
          }
        ]
      },
      {
        "type": "ia.chart.timeseries",
        "meta": { "name": "GS10Trend" },
        "position": { "grow": 1, "basis": "1" },
        "propConfig": {
          "props.series[0].data": {
            "binding": {
              "type": "tag-history",
              "config": {
                "aggregate": "MinMax",
                "avoidScanClassValidation": true,
                "dateRange": { "mostRecent": "{view.params.rangeMinutes}", "mostRecentUnits": "MIN" },
                "ignoreBadQuality": false,
                "polling": { "enabled": true, "rate": "5" },
                "preventInterpolation": false,
                "returnFormat": "Wide",
                "returnSize": { "type": "ON_CHART_REFRESH" },
                "valueFormat": "DATASET",
                "tags": [
                  { "path": "[default]MIRA_IOCheck/VFD/vfd_frequency", "alias": "OutputHz", "aggregate": "Average" },
                  { "path": "[default]MIRA_IOCheck/VFD/vfd_freq_sp", "alias": "SetpointHz", "aggregate": "Average" },
                  { "path": "[default]MIRA_IOCheck/VFD/vfd_current", "alias": "Current", "aggregate": "Average" },
                  { "path": "[default]MIRA_IOCheck/VFD/vfd_dc_bus", "alias": "DCBus", "aggregate": "Average" }
                ]
              }
            }
          }
        },
        "props": {
          "defaultStyles": { "colorScheme": "Paired" },
          "legend": { "visible": true },
          "xAxes": [],
          "series": [
            { "name": "OutputHz" },
            { "name": "SetpointHz" },
            { "name": "Current" },
            { "name": "DCBus" }
          ],
          "plots": [
            {
              "relativeWeight": 1,
              "axes": [],
              "markers": [],
              "trends": [
                { "series": "OutputHz",   "type": "line", "interpolation": "curveLinear", "breakLine": true, "visible": true, "axis": "", "radius": 0, "stack": false, "baselines": [], "columns": [] },
                { "series": "SetpointHz", "type": "line", "interpolation": "curveLinear", "breakLine": true, "visible": true, "axis": "", "radius": 0, "stack": false, "baselines": [], "columns": [] },
                { "series": "Current",    "type": "line", "interpolation": "curveLinear", "breakLine": true, "visible": true, "axis": "", "radius": 0, "stack": false, "baselines": [], "columns": [] },
                { "series": "DCBus",      "type": "line", "interpolation": "curveLinear", "breakLine": true, "visible": true, "axis": "", "radius": 0, "stack": false, "baselines": [], "columns": [] }
              ]
            }
          ]
        }
      }
    ]
  }
}
