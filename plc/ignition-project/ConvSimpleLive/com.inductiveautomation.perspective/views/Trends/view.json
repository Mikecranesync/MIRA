{
  "custom": {},
  "params": {},
  "props": { "defaultSize": { "width": 1280, "height": 800 } },
  "root": {
    "type": "ia.container.flex",
    "meta": { "name": "root" },
    "props": { "direction": "column", "style": { "backgroundColor": "#0d1117", "height": "100%" } },
    "children": [
      {
        "type": "ia.embedding.view",
        "meta": { "name": "navbar" },
        "position": { "basis": "44px", "shrink": 0 },
        "props": { "path": "NavBar", "params": { "active": "trends" } }
      },
      {
        "type": "ia.display.label",
        "meta": { "name": "trendTitle" },
        "position": { "basis": "26px", "shrink": 0 },
        "props": { "text": "LIVE TRENDS — Ignition Tag Historian (native)", "style": { "color": "#8b949e", "fontSize": "11px", "fontWeight": 700, "letterSpacing": "0.08em", "padding": "8px 14px 0 14px" } }
      },
      {
        "type": "ia.chart.powerchart",
        "meta": { "name": "PowerChart" },
        "position": { "grow": 1, "basis": "1" },
        "propConfig": {
          "props.config.tagBrowserStartPath": {
            "binding": {
              "type": "expr",
              "config": { "expression": "\"histprov:Sample_SQLite_Database:/drv:\" + {[System]Gateway/SystemName} + \":default\"" }
            }
          }
        },
        "props": {
          "config": { "visibility": { "showTagBrowser": true } },
          "interaction": { "chartZoomLevel": 1, "rangeZoomLevel": 1 }
        }
      }
    ]
  }
}
