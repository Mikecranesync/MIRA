<modbusServer Version="3.0">
  <!-- Micro820 v4.1.9 Modbus server map. 22 coils + 17 holding registers.
       Supersedes MbSrvConf_v3.xml (20 coils + 16 HRs); adds the v4.1.x VFD
       poll-state machine signals:
         coil 000021 vfd_poll_active          (Modbus message in flight to GS10)
         coil 000022 vfd_fault_reset_pending  (fault reset queued for next poll)
         HR   400117 vfd_poll_step            (1=read 2=cmd 3=freq 4=reset 5=status)
       Variable names MUST match the ladder globals exactly. Human-readable
       reference: docs/conveyor-fault-detective-demo/Micro820_v4.1.9_Modbus_Map.pdf
       (regenerate via tools/plc-modbus-map-pdf.py). Version="3.0" is the
       CCW MbSrvConf schema version, not the ladder version — do not bump. -->
  <modbusRegister name="COILS">
    <mapping variable="motor_running" parent="Micro820" dataType="Bool" address="000001">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="conveyor_running" parent="Micro820" dataType="Bool" address="000002">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="fault_alarm" parent="Micro820" dataType="Bool" address="000003">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="vfd_comm_ok" parent="Micro820" dataType="Bool" address="000004">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="system_ready" parent="Micro820" dataType="Bool" address="000005">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="e_stop_active" parent="Micro820" dataType="Bool" address="000006">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="dir_fwd" parent="Micro820" dataType="Bool" address="000007">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="dir_rev" parent="Micro820" dataType="Bool" address="000008">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="heartbeat" parent="Micro820" dataType="Bool" address="000009">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="estop_wiring_fault" parent="Micro820" dataType="Bool" address="000010">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="dir_fault" parent="Micro820" dataType="Bool" address="000011">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <!-- Raw DI states for diagnostics -->
    <mapping variable="_IO_EM_DI_00" parent="Micro820" dataType="Bool" address="000012">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DI_01" parent="Micro820" dataType="Bool" address="000013">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DI_02" parent="Micro820" dataType="Bool" address="000014">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DI_03" parent="Micro820" dataType="Bool" address="000015">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DI_04" parent="Micro820" dataType="Bool" address="000016">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DO_00" parent="Micro820" dataType="Bool" address="000017">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DO_01" parent="Micro820" dataType="Bool" address="000018">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DO_02" parent="Micro820" dataType="Bool" address="000019">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="_IO_EM_DO_03" parent="Micro820" dataType="Bool" address="000020">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <!-- v4.1.x VFD poll-state machine -->
    <mapping variable="vfd_poll_active" parent="Micro820" dataType="Bool" address="000021">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
    <mapping variable="vfd_fault_reset_pending" parent="Micro820" dataType="Bool" address="000022">
      <MBVarInfo ElemType="Bool" SubElemType="Any" DataTypeSize="1" />
    </mapping>
  </modbusRegister>
  <modbusRegister name="HOLDING_REGISTERS">
    <mapping variable="motor_speed" parent="Micro820" dataType="Int" address="400101">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="motor_current" parent="Micro820" dataType="Int" address="400102">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="temperature" parent="Micro820" dataType="Int" address="400103">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="pressure" parent="Micro820" dataType="Int" address="400104">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="conveyor_speed" parent="Micro820" dataType="Int" address="400105">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="error_code" parent="Micro820" dataType="Int" address="400106">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_frequency" parent="Micro820" dataType="Int" address="400107">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_current" parent="Micro820" dataType="Int" address="400108">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_voltage" parent="Micro820" dataType="Int" address="400109">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_dc_bus" parent="Micro820" dataType="Int" address="400110">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="item_count" parent="Micro820" dataType="Int" address="400111">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="uptime_seconds" parent="Micro820" dataType="Int" address="400112">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="conveyor_speed_cmd" parent="Micro820" dataType="Int" address="400113">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="conv_state" parent="Micro820" dataType="Int" address="400114">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_cmd_word" parent="Micro820" dataType="Int" address="400115">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <mapping variable="vfd_freq_setpoint" parent="Micro820" dataType="Int" address="400116">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
    <!-- v4.1.x VFD poll-state machine -->
    <mapping variable="vfd_poll_step" parent="Micro820" dataType="Int" address="400117">
      <MBVarInfo ElemType="Int" SubElemType="Any" DataTypeSize="2" />
    </mapping>
  </modbusRegister>
</modbusServer>
