# MIRA .env.template — All variables documented. No real values here.
# Copy to .env and fill in LOCAL CONFIG section only.
# Doppler-managed vars are injected automatically via: doppler run -- docker compose up -d

# ============================================================
# DOPPLER-MANAGED (factorylm/prd) — do not set here
# ============================================================
# WEBUI_SECRET_KEY=       # rotated 2026-03-18, set in Doppler
# MCPO_API_KEY=           # rotated 2026-03-18, set in Doppler
# TELEGRAM_BOT_TOKEN=     # Telegram bot token
# SLACK_BOT_TOKEN=        # xoxb-...
# SLACK_APP_TOKEN=        # xapp-...
# MCP_REST_API_KEY=       # Bearer token for mira-mcp REST API
# OPENWEBUI_API_KEY=      # sk-...
# KNOWLEDGE_COLLECTION_ID=# Open WebUI knowledge collection UUID
# NEON_DATABASE_URL=      # postgresql://... NeonDB connection string
# MIRA_TENANT_ID=         # UUID for this deployment
# INFERENCE_BACKEND=      # "claude" or "local"
# ANTHROPIC_API_KEY=      # sk-ant-...
# CLAUDE_MODEL=           # default: claude-3-5-sonnet-20241022
# MIRA_SERVER_BASE_URL=   # BRAVO host for remote clients (e.g. http://192.168.1.11)
# TEAMS_APP_ID=           # Azure Bot App ID (Phase 2.3)
# TEAMS_APP_PASSWORD=     # Azure Bot client secret (Phase 2.3)
# TWILIO_ACCOUNT_SID=     # Twilio Account SID (Phase 2.4)
# TWILIO_AUTH_TOKEN=      # Twilio Auth Token (Phase 2.4)
# TWILIO_WHATSAPP_FROM=   # whatsapp:+1415XXXXXXX (Phase 2.4)
# LANGFUSE_SECRET_KEY=    # Langfuse secret key (from langfuse.com/settings)
# LANGFUSE_PUBLIC_KEY=    # Langfuse public key (from langfuse.com/settings)
# LANGFUSE_HOST=          # Optional — defaults to https://cloud.langfuse.com
# MIRA_DRIVE_FOLDER_ID=  # Google Drive folder for photo pipeline uploads

# ============================================================
# mira-web Stripe + Beta Onboarding (Doppler-managed)
# ============================================================
# STRIPE_SECRET_KEY=      # Stripe API secret key (sk_live_... or sk_test_...)
# STRIPE_WEBHOOK_SECRET=  # Stripe webhook signing secret (whsec_...)
# STRIPE_PRICE_ID=        # Price ID for $97/mo beta subscription (price_...)
# PLG_JWT_SECRET=         # JWT signing key for mira-web sessions
# RESEND_API_KEY=         # Resend API key for transactional email
# LOOM_URL_1=             # Day 1 Loom: Dramatic Demonstration (fault diagnosis)
# LOOM_URL_2=             # Day 2 Loom: CMMS walkthrough
# LOOM_URL_3=             # Day 3 Loom: Manual upload + RAG demo
# LOOM_URL_4=             # Day 5 Loom: Slack + Telegram integrations
# LOOM_URL_5=             # Day 6 Loom: Social proof (optional)

# ============================================================
# ATLAS CMMS (Doppler-managed secrets, local config below)
# ============================================================
# ATLAS_DB_PASSWORD=      # PostgreSQL password for Atlas CMMS
# ATLAS_JWT_SECRET=       # JWT signing key for Atlas API auth
# ATLAS_MINIO_PASSWORD=   # MinIO root password for file storage
# ATLAS_API_USER=         # Atlas CMMS admin email (for mira-mcp integration)
# ATLAS_API_PASSWORD=     # Atlas CMMS admin password (for mira-mcp integration)

# ============================================================
# LOCAL CONFIG — set these in your .env file
# ============================================================

# Port overrides (defaults shown)
WEBUI_PORT=3000
MCPO_PORT=8000
INGEST_PORT=8002
NODERED_PORT=1880
TEAMS_PORT=8030
WHATSAPP_PORT=8010

# Ollama model selection (defaults shown)
VISION_MODEL=qwen2.5vl:7b
GLM_OCR_MODEL=glm4v:9b-q4_0

# Groq vision model for image analysis (free tier)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Image processing
MAX_VISION_PX=512
MAX_INGEST_PX=1024

# Atlas CMMS ports (defaults avoid conflicts with MIRA services)
ATLAS_DB_PORT=5433
ATLAS_API_PORT=8088
ATLAS_FRONTEND_PORT=3100
ATLAS_MINIO_API_PORT=9000
ATLAS_MINIO_CONSOLE_PORT=9001
ATLAS_PUBLIC_API_URL=http://localhost:8088
ATLAS_PUBLIC_FRONT_URL=http://localhost:3100
ATLAS_PUBLIC_MINIO_URL=http://localhost:9000

# Timezone
TZ=America/New_York

# Open WebUI base URL (internal Docker network)
OPENWEBUI_BASE_URL=http://mira-core:8080

# Open WebUI user/session forwarding (required for multi-user pipeline)
ENABLE_FORWARD_USER_INFO_HEADERS=true

# Database path (mounted volume)
MIRA_DB_PATH=/data/mira.db

# Slack channel filtering (optional — leave blank to allow all channels)
# SLACK_ALLOWED_CHANNELS=C01234567,C09876543

# Reddit Benchmark Agent
REDDIT_BENCHMARK_ENABLED=0

# Reddit Bot (OAuth2 script app — register at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDITS=IndustrialMaintenance,PLC,electricians,HVAC,AutomationTechnology
REDDIT_POLL_INTERVAL=120
REDDIT_DRY_RUN=0

# Test runner result notifications
TELEGRAM_TEST_RESULTS_CHAT_ID=   # Your personal Telegram user ID or private group ID.
                                  # Results post here after each run.
                                  # Find your ID: message @userinfobot

# WhatsApp signature validation (set false for local dev only)
TWILIO_VALIDATE_SIGNATURE=true

# ============================================================
# ENGINE TUNING (defaults shown)
# ============================================================
MCP_BASE_URL=http://mira-mcp:8001
MIRA_HISTORY_LIMIT=20
MIRA_PHOTO_MEMORY_TURNS=10

# ============================================================
# INGEST SERVICE MODELS (defaults shown)
# ============================================================
DESCRIBE_MODEL=llava:13b
EMBED_VISION_MODEL=nomic-embed-text
EMBED_TEXT_MODEL=nomic-embed-text

# ============================================================
# TELEGRAM TEST RUNNER (Doppler-managed)
# ============================================================
# TELEGRAM_API_ID=          # Telethon API ID (my.telegram.org)
# TELEGRAM_API_HASH=        # Telethon API hash (my.telegram.org)
# TELEGRAM_BOT_USERNAME=    # Bot username without @ prefix

# ── Observability Stack ──────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=mira2026
GRAFANA_PASSWORD=mira2026

# Reddit → Telegram Pipeline (tools/reddit_tg_pipeline/)
# TELEGRAM_TARGET=          # @channel or chat ID for Reddit curation posts
# MIN_UPVOTES=              # (optional) min score threshold, default 10
# MAX_ITEMS_PER_SUB=        # (optional) posts per subreddit, default 100
# MESSAGE_DELAY_SECS=       # (optional) inter-message delay, default 3.0

# ============================================================
# MIRA PIPELINE (OpenAI-compatible GSD wrapper for Open WebUI)
# ============================================================
PIPELINE_PORT=9099
PIPELINE_API_KEY=             # Bearer token for pipeline API (Doppler-managed)

# ============================================================
# DOCLING (Industrial PDF extraction)
# ============================================================
DOCLING_PORT=5001
