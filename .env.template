# MIRA .env.template — All variables documented. No real values here.
# Copy to .env and fill in LOCAL CONFIG section only.
# Doppler-managed vars are injected automatically via: doppler run -- docker compose up -d

# ============================================================
# DOPPLER-MANAGED (factorylm/prd) — do not set here
# ============================================================
# WEBUI_SECRET_KEY=       # rotated 2026-03-18, set in Doppler
# MCPO_API_KEY=           # rotated 2026-03-18, set in Doppler
# TELEGRAM_BOT_TOKEN=     # Telegram bot token
# SLACK_BOT_TOKEN=        # xoxb-...
# SLACK_APP_TOKEN=        # xapp-...
# MCP_REST_API_KEY=       # Bearer token for mira-mcp REST API
# OPENWEBUI_API_KEY=      # sk-...
# KNOWLEDGE_COLLECTION_ID=# Open WebUI knowledge collection UUID
# NEON_DATABASE_URL=      # postgresql://... NeonDB connection string
# MIRA_TENANT_ID=         # UUID for this deployment
# INFERENCE_BACKEND=      # "claude" or "local"
# ANTHROPIC_API_KEY=      # sk-ant-...
# CLAUDE_MODEL=           # default: claude-3-5-sonnet-20241022
# MIRA_SERVER_BASE_URL=   # BRAVO host for remote clients (e.g. http://192.168.1.11)
# TEAMS_APP_ID=           # Azure Bot App ID (Phase 2.3)
# TEAMS_APP_PASSWORD=     # Azure Bot client secret (Phase 2.3)
# TWILIO_ACCOUNT_SID=     # Twilio Account SID (Phase 2.4)
# TWILIO_AUTH_TOKEN=      # Twilio Auth Token (Phase 2.4)
# TWILIO_WHATSAPP_FROM=   # whatsapp:+1415XXXXXXX (Phase 2.4)
# LANGFUSE_SECRET_KEY=    # Langfuse secret key (from langfuse.com/settings)
# LANGFUSE_PUBLIC_KEY=    # Langfuse public key (from langfuse.com/settings)
# LANGFUSE_HOST=          # Optional — defaults to https://cloud.langfuse.com
# MIRA_DRIVE_FOLDER_ID=  # Google Drive folder for photo pipeline uploads

# ============================================================
# LOCAL CONFIG — set these in your .env file
# ============================================================

# Port overrides (defaults shown)
WEBUI_PORT=3000
MCPO_PORT=8000
INGEST_PORT=8002
NODERED_PORT=1880
TEAMS_PORT=8030
WHATSAPP_PORT=8010

# Ollama model selection (defaults shown)
VISION_MODEL=qwen2.5vl:7b
GLM_OCR_MODEL=glm4v:9b

# Image processing
MAX_VISION_PX=512
MAX_INGEST_PX=1024

# Timezone
TZ=America/New_York

# Open WebUI base URL (internal Docker network)
OPENWEBUI_BASE_URL=http://mira-core:8080

# Database path (mounted volume)
MIRA_DB_PATH=/data/mira.db

# Slack channel filtering (optional — leave blank to allow all channels)
# SLACK_ALLOWED_CHANNELS=C01234567,C09876543

# Reddit Benchmark Agent
REDDIT_BENCHMARK_ENABLED=0

# Test runner result notifications
TELEGRAM_TEST_RESULTS_CHAT_ID=   # Your personal Telegram user ID or private group ID.
                                  # Results post here after each run.
                                  # Find your ID: message @userinfobot

# WhatsApp signature validation (set false for local dev only)
TWILIO_VALIDATE_SIGNATURE=true
