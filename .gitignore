artifacts/latest_run/
artifacts/v2/
.pytest_cache/
*.log
tests/results/

# SQLite databases + WAL files
*.db
*.db-shm
*.db-wal
/data/
/output/
# Session photos (transient, saved per-chat for photo memory)
**/session_photos/
mira-bots/benchmark_results/
mira-bots/tools/output/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Orphan directories
mira-bots-phase1/
mira-bots-phase2/
mira-bots-phase3/

# State / local planning (not code)
.planning/

# Node
node_modules/

# Secrets directory (empty — kept as marker)
Secrets/

# Backup files
*.bak

# Archives (large binary blobs)
archives/

# Equipment photos (synced via rclone, never committed)
mira-core/data/equipment_photos/

# Google Drive ingest staging (downloaded docs, never committed)
mira-core/data/gdrive_ingest/

# Manual PDFs (stored locally, not committed to git)
mira-core/data/manuals/

# Crawler runtime data (cache, dedup DBs, logs, incoming docs)
mira-crawler/data/

# gdrive_photo_scanner idempotency state (per-VPS, regenerated on every run)
mira-crawler/agents/gdrive_photo_scanner_state.json

# Test photos (real equipment photos, synced separately)
tests/regime1_telethon/photos/
tests/regime3_nameplate/photos/real/

# QA regression run outputs (raw json + Markdown reports)
tests/qa_regression/runs/
dogfood-output/synthetic-dogfood/

# Local backups
backups/

# Accidental Docker container extraction artifacts
usr/

# GitHub Actions cache
.github/actions-cache/

# Claude Code runtime files
.claude/scheduled_tasks.lock

# Obsidian vault config (wiki is git-tracked, but Obsidian settings are local)
wiki/.obsidian/

# Cloned SDK repos (have their own .git)
ignition-sdk-examples/

# Photos directory (local screenshots/images)
Pics/

# Paperclip runtime artifacts (secrets, local DB)
paperclip/.env.paperclip
paperclip/.generated/

# uv lock file (generated, not committed — except for Docker-built services)
uv.lock
!mira-sidecar/uv.lock

# ML model weights (downloaded at runtime, never committed)
yolov8n.pt
models/*.pt

# MIRA Sidecar runtime data
mira-sidecar/chroma_data/
mira-sidecar/docs/
mira-sidecar/logs/
mira-sidecar/.venv/
factorylm.properties

# Observability data volumes (managed by Docker)
observability/grafana/provisioning/dashboards/celery-tasks.json
.hypothesis/

# Test coverage artifacts
.coverage
.coverage.*
htmlcov/

# Playwright MCP session ephemera (per-session, regenerable)
.playwright-mcp/

# Playwright browser cache + per-run test output (regenerable)
.playwright-cache/
test-results/

# Claude Code project-local settings (per-machine; never commit)
.claude/settings.local.json

# Web-review skill working directories (bare-date dirs hold node_modules,
# audit JSON, probe scripts — regenerable). Per-PR proof dirs (date-pr-NNN)
# are explicitly tracked.
tools/web-review-runs/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Marketing video binaries — large, regenerable; keep spend.json tracked
marketing/videos/**/*.mp4
marketing/videos/**/*.mov
marketing/videos/**/*.webm
marketing/videos/**/*.mp3
marketing/videos/**/*.wav
marketing/videos/**/*.ogg
marketing/videos/**/*.m4a

# Obsidian per-machine state (track plugin config under .obsidian/, not these)
wiki/.obsidian/workspace*
wiki/.obsidian/app.json
wiki/.obsidian/appearance.json
wiki/.smart-env/

# iCloud sync duplicates (filename ending in " 2.ext"). Keep them out of
# the repo even if iCloud re-creates them locally.
**/* 2.md
**/* 2.txt

.claire/

# Third-party AI tool runtime dirs (local config, not code)
.agents/
.codex/
.serena/

# Comic-pipeline reference images (large generated PNGs, regenerable)
marketing/comic-pipeline/reference/*.png
marketing/comic-pipeline/reference/*.v*.png

# Video frame proof-of-work jpegs (root-level, regenerable)
frame-shot*.jpeg

# Ralph loop local config
.claude/ralph-loop.local.md

# Playwright marketplace-setup runs (screenshots-on-failure, never commit)
tools/monday-marketplace-setup/runs/
tools/monday-marketplace-setup/node_modules/
tools/monday-marketplace-setup/playwright-report/
tools/monday-marketplace-setup/.chrome-profile/
.warp/mcp.json

# Staging test output (regenerable; never commit result snapshots)
staging_results.json
tools/staging_results.json

# CodeGraph local index (machine-specific, regenerable via `npx @colbymchenry/codegraph index`)
.codegraph/

# Product Orchestrator generated output (regenerated every run by tools/orchestrator/).
# Track the tooling + HISTORY.md + hand-authored plans; never the generated state.
wiki/orchestrator/scan.json
wiki/orchestrator/state.json
wiki/orchestrator/artifact.html
wiki/orchestrator/STATE.md

# Eval record/replay stores — record locally (MIRA_EVAL_REPLAY=record); not a
# bit-stable baseline yet (engine has residual nondeterminism — see HANDOFF).
tests/eval/fixtures/llm_replay/*.json

# MIRA local AnswerTrace output (observability layer, MIRA_LOCAL_TRACE=1)
.mira-traces/
.mira-phase1-traces/

# --- accumulated session artifacts (added 2026-06-16 working-tree untangle) ---
# Offline eval run logs (regenerated every run by tests/eval/; ~40+ accreted).
tests/eval/runs/

# Orchestrator-pulse generated findings (per-agent JSONL + git bundle).
# Hand-authored plans/patches under wiki/orchestrator/ stay tracked — only the
# generated findings/bundle are noise. (graph.json already ignored above.)
wiki/orchestrator/kg/*-findings.jsonl
wiki/orchestrator/kg/*-route-auth.jsonl
wiki/orchestrator/*.bundle

# Generated reports/exports dropped at repo root (regenerable; never the source).
# Specific paths only — docs/ PDFs and docs/promo-screenshots/*.png stay tracked.
/FactoryLM_Lead_Pipeline_2026.xlsx
/FactoryLM_Path_to_Beta_2026.pdf
/i3x-strategy-report.pdf
/ignition-tag-readiness-report.pdf
/stripe-go-live-guide.pdf
/xprize-70-day-sprint-plan.pdf
/xprize-registration-brief.pdf
/proposal-card-before-after.png
/err.txt
proof_simlab.db

# SDD subagent-driven-development scratch (briefs/reports/ledger)
.superpowers/

# KB growth cron runtime ingest-queue state (pending/done/failed manuals +
# timestamps/attempts). Runtime file is at /var/lib/mira/manual_queue.json
# (configurable via MIRA_MANUAL_QUEUE_PATH env var), outside the repo tree so it
# survives deploy-vps.yml's `git checkout --force <tag>` on /opt/mira.
# The mira-crawler/cron/ template is shipped as reference only (not runtime).
mira-crawler/cron/manual_queue.json

# regime3 golden-label local overlays (customer-project cases live local-only)
tests/regime3_nameplate/golden_labels/**/*.local.json

# factorylm_ai local data (never commit)
factorylm_ai/data/
factorylm_ai/proofpack/reports/
.venv-flmai/
