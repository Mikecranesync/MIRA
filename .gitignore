# Generated marketing content (mira-copy outputs)
mira_copy/outputs/*
!mira_copy/outputs/.gitkeep

# Session ephemera — PR/issue drafts, one-off probe scripts, worktree parent
.tmp_*
.claude/worktrees/
.worktrees/
# nested audit worktrees — MUST stay ignored: CodeGraph indexes any non-ignored
# nested worktree, inflating every caller/callee/impact count with duplicate copies.
.audit-worktrees/
.claude/scratchpad/

# Auto-log target for .claude/hooks/stop.sh — per-machine session history
docs/context/PROGRESS.local.md

# Skill eval workspaces (skill-creator iteration runs; rebuilt locally per session)
.claude/skills/*-workspace/

# Secrets — NEVER commit these
.env
*.env.local
mira-core/.env
mira-bots/.env
mira-mcp/.env
mira-cmms/.env

# Staging directories (large binaries, local PDFs)
bravo/Send to Bravo/
MIRA test case 1/
tools/ingest_local_pdfs.py

# HUD session logs
mira-hud/vision_backend/logs/

# Telethon sessions
*.session
*.session-journal

# Playwright auth fixtures — contain logged-in session cookies
mira-hub/tests/e2e/fixtures/storageState.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

