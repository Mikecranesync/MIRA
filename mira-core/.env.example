# mira-core — Open WebUI configuration
WEBUI_PORT=3000
WEBUI_AUTH=true
ENABLE_SIGNUP=false

# mcpo — MCP-to-HTTP proxy
MCPO_API_KEY=your-mcpo-api-key-here
MCPO_PORT=8000

# mira-ingest — Photo ingestion service
INGEST_PORT=8002
EMBED_VISION_MODEL=nomic-embed-vision-v1.5
EMBED_TEXT_MODEL=nomic-embed-text-v1.5

# Prerequisites:
# 1. Ollama running on host: ollama serve
# 2. Model pulled: ollama pull qwen2.5:7b-instruct-q4_K_M
# 3. MIRA model created: ollama create mira -f Modelfile
# 4. Networks created:
#    docker network create core-net
#    docker network create bot-net
