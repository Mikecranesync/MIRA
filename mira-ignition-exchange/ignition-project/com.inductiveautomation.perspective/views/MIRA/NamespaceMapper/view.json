            "version": 0,
            "props": {"path": "material/check_circle", "color": "#059669", "style": {"width": "18px", "height": "18px"}},
            "meta": {"name": "statusIcon"},
            "position": {"shrink": 0}
          },
          {
            "type": "ia.display.label",
            "version": 0,
            "props": {"text": "", "style": {"color": "#065F46", "fontSize": "13px", "fontWeight": "500"}},
            "meta": {"name": "statusText"},
            "position": {"grow": 1},
            "propConfig": {
              "props.text": {
                "binding": {
