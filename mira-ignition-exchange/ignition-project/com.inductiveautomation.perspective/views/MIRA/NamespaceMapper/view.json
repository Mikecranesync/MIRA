{
  "custom": {
    "tagFolder": "[default]",
    "activeTab": "uns",
    "mapState": "idle",
    "errorMessage": "",
    "proposals": [],
    "selectedRows": [],
    "stats": {"accepted": 0, "rejected": 0, "pending": 0},
    "unsPrefix": {"enterprise": "enterprise", "site": "site", "area": "area", "line": "line"}
  },
  "params": {
    "tagFolder": {
      "type": "string",
      "value": "[default]",
      "description": "Initial tag provider+folder to map (e.g. [default]MyPLC). Passed by embedding views."
    }
  },
  "props": {
    "defaultSize": {
      "width": 1100,
      "height": 720
    }
  },
  "root": {
    "type": "ia.container.flex",
    "version": 0,
    "props": {
      "direction": "column",
      "alignItems": "stretch",
      "justifyContent": "flex-start",
      "style": {
        "backgroundColor": "#F4F6F8",
        "fontFamily": "Roboto, sans-serif",
        "height": "100%"
      }
    },
    "meta": {"name": "root"},
    "position": {"grow": 1},
    "children": [

      {
        "type": "ia.container.flex",
        "version": 0,
        "props": {
          "direction": "row",
          "alignItems": "center",
          "justifyContent": "space-between",
          "style": {
            "backgroundColor": "#0E1A2B",
            "color": "#FFFFFF",
            "padding": "12px 16px",
            "borderBottom": "1px solid #1B2A41"
          }
        },
        "meta": {"name": "headerBar"},
        "position": {"basis": "56px", "shrink": 0},
        "children": [
          {
            "type": "ia.container.flex",
            "version": 0,
            "props": {
              "direction": "row",
              "alignItems": "center",
              "style": {"gap": "10px"}
            },
            "meta": {"name": "logoGroup"},
            "position": {"grow": 0},
            "children": [
              {
                "type": "ia.display.icon",
                "version": 0,
                "props": {
                  "path": "material/account_tree",
                  "color": "#5BC0EB",
                  "style": {"width": "28px", "height": "28px"}
                },
                "meta": {"name": "mapperIcon"},
                "position": {"basis": "28px", "shrink": 0}
              },
              {
                "type": "ia.display.label",
                "version": 0,
                "props": {
                  "text": "MIRA Namespace Mapper",
                  "style": {
                    "color": "#FFFFFF",
                    "fontSize": "18px",
                    "fontWeight": "700",
                    "letterSpacing": "1px"
                  }
                },
                "meta": {"name": "title"},
                "position": {"shrink": 0}
              }
            ]
          },
          {
            "type": "ia.display.label",
            "version": 0,
            "props": {
              "text": "Powered by FactoryLM",
              "style": {
                "color": "#A8B5C7",
                "fontSize": "11px",
                "fontWeight": "400",
                "textTransform": "uppercase",
                "letterSpacing": "0.5px"
              }
            },
            "meta": {"name": "poweredBy"},
            "position": {"shrink": 0}
          }
        ]
      },

      {
        "type": "ia.container.flex",
        "version": 0,
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "backgroundColor": "#FFFFFF",
            "borderBottom": "1px solid #E0E0E0",
            "padding": "8px 16px",
            "gap": "10px"
          }
        },
        "meta": {"name": "configBar"},
        "position": {"basis": "52px", "shrink": 0},
        "children": [
          {
            "type": "ia.display.label",
            "version": 0,
            "props": {
              "text": "Tag Folder:",
              "style": {"fontSize": "13px", "color": "#374151", "fontWeight": "500", "whiteSpace": "nowrap"}
            },
            "meta": {"name": "folderLabel"},
            "position": {"shrink": 0}
          },
          {
            "type": "ia.input.text-field",
            "version": 0,
            "props": {
              "value": "",
              "placeholderText": "[default]  or  [default]MyPLC/ConveyorLine",
              "style": {"fontSize": "13px", "minWidth": "280px"}
            },
            "meta": {"name": "folderInput"},
            "position": {"grow": 1},
            "propConfig": {
              "props.value": {
                "binding": {
                  "type": "property",
                  "config": {"path": "view.custom.tagFolder"}
                }
              }
            },
            "events": {
              "component": {
                "onValueChange": [
                  {
                    "type": "script",
                    "scope": "G",
                    "config": {
                      "script": "self.view.custom.tagFolder = str(currentValue.value)"
                    }
                  }
                ]
              }
            }
          },
          {
            "type": "ia.input.button",
            "version": 0,
            "props": {
              "text": "Map Tags",
              "style": {
                "backgroundColor": "#0E1A2B",
                "color": "#FFFFFF",
                "fontWeight": "600",
                "padding": "8px 18px",
                "borderRadius": "5px",
                "fontSize": "13px"
              }
            },
            "meta": {"name": "mapButton"},
            "position": {"shrink": 0},
            "events": {
              "component": {
                "onActionPerformed": [
                  {
                    "type": "script",
                    "scope": "G",
                    "config": {
                      "script": "import system\n\nfolder = str(self.view.custom.tagFolder).strip()\nif not folder:\n    self.view.custom.errorMessage = 'Enter a tag folder path (e.g. [default]MyPLC).'\n    self.view.custom.mapState = 'error'\n    return\n\nself.view.custom.mapState = 'loading'\nself.view.custom.errorMessage = ''\n\ntry:\n    api_url = str(system.tag.readBlocking(['[default]MIRA/namespace_map_api_url'])[0].value).strip()\n    if not api_url or api_url in ('null', 'None', ''):\n        api_url = 'http://localhost:8088/system/webdev/FactoryLM/api/namespace'\n    url = api_url + '?folder=' + folder + '&recurse=true'\n    client = system.net.httpClient(timeout=30000)\n    resp = client.get(url=url, headers={'Accept': 'application/json'})\n    if resp.good:\n        data = resp.getJson()\n        proposals = list(data.get('proposals', []))\n        self.view.custom.proposals = proposals\n        pfix = data.get('uns_prefix', {})\n        self.view.custom.unsPrefix = {\n            'enterprise': str(pfix.get('enterprise', 'enterprise')),\n            'site': str(pfix.get('site', 'site')),\n            'area': str(pfix.get('area', 'area')),\n            'line': str(pfix.get('line', 'line'))\n        }\n        accepted = sum(1 for p in proposals if str(p.get('status', '')) == 'accepted')\n        rejected = sum(1 for p in proposals if str(p.get('status', '')) == 'rejected')\n        pending  = len(proposals) - accepted - rejected\n        self.view.custom.stats = {'accepted': accepted, 'rejected': rejected, 'pending': pending}\n        self.view.custom.mapState = 'mapped'\n    else:\n        self.view.custom.errorMessage = 'Map request failed: HTTP ' + str(resp.statusCode)\n        self.view.custom.mapState = 'error'\nexcept Exception as e:\n    self.view.custom.errorMessage = 'Error mapping tags: ' + str(e)\n    self.view.custom.mapState = 'error'\n"
                    }
                  }
                ]
              }
            }
          },
          {
            "type": "ia.display.label",
            "version": 0,
            "props": {
              "text": "|",
              "style": {"color": "#D1D5DB", "fontSize": "18px", "padding": "0 4px"}
            },
            "meta": {"name": "divider1"},
            "position": {"shrink": 0}
          },
          {
            "type": "ia.input.button",
            "version": 0,
            "props": {
              "text": "UNS Namespace",
              "style": {
                "fontWeight": "600",
                "fontSize": "13px",
                "padding": "8px 14px",
                "borderRadius": "5px",
                "border": "2px solid transparent"
              }
            },
            "meta": {"name": "tabUns"},
            "position": {"shrink": 0},
            "propConfig": {
              "props.style.backgroundColor": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.activeTab} = 'uns', '#0E1A2B', '#F3F4F6')"
                  }
                }
              },
              "props.style.color": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.activeTab} = 'uns', '#FFFFFF', '#374151')"
                  }
                }
              }
            },
            "events": {
              "component": {
                "onActionPerformed": [
                  {
                    "type": "script",
                    "scope": "G",
                    "config": {"script": "self.view.custom.activeTab = 'uns'"}
                  }
                ]
              }
            }
          },
          {
            "type": "ia.input.button",
            "version": 0,
            "props": {
              "text": "i3X",
              "style": {
                "fontWeight": "600",
                "fontSize": "13px",
                "padding": "8px 14px",
                "borderRadius": "5px"
              }
            },
            "meta": {"name": "tabI3x"},
            "position": {"shrink": 0},
            "propConfig": {
              "props.style.backgroundColor": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.activeTab} = 'i3x', '#0E1A2B', '#F3F4F6')"
                  }
                }
              },
              "props.style.color": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({view.custom.activeTab} = 'i3x', '#FFFFFF', '#374151')"
                  }
                }
              }
            },
            "events": {
              "component": {
                "onActionPerformed": [
                  {
                    "type": "script",
                    "scope": "G",
                    "config": {"script": "self.view.custom.activeTab = 'i3x'"}
                  }
                ]
              }
            }
          }
        ]
      },

