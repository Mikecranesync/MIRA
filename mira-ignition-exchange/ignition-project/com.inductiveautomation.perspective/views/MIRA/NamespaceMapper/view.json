                  "config": {"expression": "{view.custom.mapState} = 'saved'"}
                }
              }
            }
          }
        ]
      },

      {
        "type": "ia.container.flex",
        "version": 0,
        "props": {
          "direction": "row",
          "alignItems": "center",
          "style": {
            "backgroundColor": "#FEF3C7",
            "borderBottom": "1px solid #FDE68A",
            "padding": "8px 16px",
            "gap": "8px"
          },
          "visible": false
        },
        "meta": {"name": "loadingBanner"},
        "position": {"basis": "40px", "shrink": 0},
        "propConfig": {
          "props.visible": {
            "binding": {
              "type": "expr",
              "config": {"expression": "{view.custom.mapState} = 'loading'"}
