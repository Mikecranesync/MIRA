<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for MIRA API + Groq Whisper -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Microphone for voice input (Groq Whisper transcription) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Camera for equipment identification -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Storage for temp audio/photo files -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- Camera is required — RealWear has camera -->
    <uses-feature android:name="android.hardware.camera" android:required="true"/>
    <uses-feature android:name="android.hardware.microphone" android:required="true"/>

    <application
        android:label="MIRA"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="landscape">

            <!-- WearHF voice activation intent filter (RealWear-specific) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="mira"/>
            </intent-filter>

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
        </activity>

        <!-- Don't delete the meta-data below — Flutter needs it -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>

    <!-- Required to query RealWear WearHF service -->
    <queries>
        <package android:name="com.realwear.wearhf"/>
    </queries>
</manifest>
