# =============================================================================
# Stripe Connect Sample — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# NEVER commit your real `.env` (it is git-ignored). Get your keys from the
# Stripe Dashboard: https://dashboard.stripe.com/test/apikeys
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — your platform account's secret API key.
# -----------------------------------------------------------------------------
# This is the key for the PLATFORM (your) Stripe account — the account that
# owns the connected accounts. Use a TEST-mode key (sk_test_...) until the
# whole flow is verified end-to-end. The server refuses to boot without it.
# PLACEHOLDER: replace with your own test secret key.
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER

# -----------------------------------------------------------------------------
# REQUIRED for the Connect (thin-event) webhook — see section 4 of the README.
# -----------------------------------------------------------------------------
# Signing secret for the V2 *thin-event* webhook endpoint (/webhooks/connect).
# When testing locally with the Stripe CLI, `stripe listen` prints a LOCAL
# whsec_... — paste it here. In production, this is the endpoint's signing
# secret from the Dashboard.
# PLACEHOLDER: replace with the whsec_... printed by `stripe listen`.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_PLACEHOLDER

# -----------------------------------------------------------------------------
# REQUIRED for the subscription (standard V1-event) webhook — see section 9.
# -----------------------------------------------------------------------------
# Signing secret for the standard V1-event webhook endpoint (/webhooks/subscriptions).
# This is a SEPARATE endpoint from the thin-event one above, so it gets its own
# signing secret. With the CLI, run a second `stripe listen` (without
# --thin-events) and paste its whsec_... here.
# PLACEHOLDER: replace with the whsec_... for the standard-events listener.
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_PLACEHOLDER

# -----------------------------------------------------------------------------
# REQUIRED for the subscription demo (section 8).
# -----------------------------------------------------------------------------
# A recurring Price ID on your PLATFORM account that connected accounts will be
# subscribed to (e.g. a "$X/month platform fee"). Create one in the Dashboard
# or with: `stripe prices create --unit-amount 9700 --currency usd \
#   -d "recurring[interval]=month" --product prod_XXX`
# PLACEHOLDER: replace with your recurring price id.
PRICE_ID=price_PLACEHOLDER

# -----------------------------------------------------------------------------
# OPTIONAL — public base URL used to build return/refresh/success URLs.
# -----------------------------------------------------------------------------
# Defaults to http://localhost:PORT. Set this to your tunnel/host when running
# behind ngrok or a deployed URL so Stripe redirects land back on this app.
# PLACEHOLDER: set to your public URL when not running purely on localhost.
PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# OPTIONAL — HTTP port. Defaults to 4242.
# -----------------------------------------------------------------------------
PORT=4242
